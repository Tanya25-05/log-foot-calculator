---
const { items = [] } = Astro.props;
---

<div class="space-y-3">
  {items.map((item, i) => (
    <details class="group linear-card p-5">
      <summary class="flex cursor-pointer items-center justify-between text-body-md-strong text-primary list-none" data-i18n={`faq.q${i + 1}`}>
        {item.question}
        <svg class="h-4 w-4 text-muted shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </summary>
      <p class="mt-3 text-body-sm text-secondary" data-i18n-html={`faq.a${i + 1}`}>
        {item.answer}
      </p>
    </details>
  ))}
</div>
