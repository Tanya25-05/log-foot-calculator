---
import Card from "./Card.astro";
import InputField from "./InputField.astro";
---

<section
  id="calculator"
  class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16"
  data-calculator-root
>
  <!-- Section Heading -->
  <div class="mb-10 text-center">
    <span class="inline-block rounded-full bg-secondary px-3 py-1 text-caption-mono font-mono uppercase tracking-wide text-muted">
      Free Online Tool
    </span>
    <h2 class="mt-4 text-display-xl text-primary text-balance">
      Board Foot Calculator.
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-body-lg text-secondary">
      Real-time lumber calculations with a visual preview and a project cut list that saves to your browser.
    </p>
  </div>

  <!-- Unit Toggle -->
  <div class="mb-8 flex items-center justify-center gap-3">
    <span class="text-body-sm text-secondary" data-unit-label-imperial>Imperial</span>
    <button
      data-unit-toggle
      class="relative inline-flex h-6 w-10 cursor-pointer items-center rounded-full border border-subtle bg-primary transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-accent-mustard/40"
      role="switch"
      aria-checked="false"
      aria-label="Toggle metric units"
    >
      <span class="inline-block h-4 w-4 translate-x-0.5 transform rounded-full bg-accent-mustard transition-transform duration-200" data-toggle-dot></span>
    </button>
    <span class="text-body-sm text-secondary" data-unit-label-metric>Metric</span>
  </div>

  <!-- Calculator Layout: 2-col top + full-width cut list below -->
  <div class="calculator-layout">

    <!-- Board Dimensions — Column 1 -->
    <div>
      <Card>
        <div class="mb-6 flex items-center justify-between">
          <h3 class="text-display-sm text-primary">Board Dimensions</h3>
          <span class="text-caption font-mono text-muted uppercase tracking-wide" data-unit-labels>in / ft</span>
        </div>

        <div class="mb-6" data-presets-root>
          <span class="mb-3 block text-body-sm-strong text-secondary uppercase tracking-wide">Quick Fill</span>
          <div class="flex flex-wrap gap-2" data-presets-list>
            <button data-preset="1.5,3.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×4 — 8'</button>
            <button data-preset="1.5,3.5,10" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×4 — 10'</button>
            <button data-preset="1.5,5.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×6 — 8'</button>
            <button data-preset="1.5,7.25,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×8 — 8'</button>
            <button data-preset="3.5,3.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">4×4 — 8'</button>
            <button data-preset="0.75,5.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">1×6 — 8'</button>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-x-4 gap-y-5 sm:grid-cols-4">
          <InputField label="Thickness" unit="in" step="0.25" min="0.1" value="1.5" dataInput="thickness" dataUnitLabel="thickness" />
          <InputField label="Width" unit="in" step="0.25" min="0.1" value="3.5" dataInput="width" dataUnitLabel="width" />
          <InputField label="Length" unit="ft" step="0.5" min="0.5" value="8" dataInput="length" dataUnitLabel="length" />
          <InputField label="Quantity" step="1" min="1" value="1" dataInput="quantity" />
        </div>

        <div class="mt-6 grid grid-cols-2 gap-x-4 sm:grid-cols-4">
          <div class="sm:col-span-1">
            <InputField label="Price / BF" unit="$/BF" step="0.01" min="0" value="0" dataInput="price" dataUnitLabel="price" />
          </div>
          <div class="flex items-end sm:col-span-1 sm:col-start-4">
            <button
              data-action="add-to-cart"
              class="w-full rounded-lg bg-accent-mustard px-4 py-2.5 text-body-md-strong text-white transition-opacity hover:opacity-90 cursor-pointer"
            >
              Add to Cut List
            </button>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-3 gap-4 rounded-lg bg-secondary p-4">
          <div class="text-center">
            <span class="text-caption text-secondary">Per Board</span>
            <p class="mt-0.5 text-display-sm text-primary" data-result-bf>0 BF</p>
          </div>
          <div class="text-center">
            <span class="text-caption text-secondary">Total BF</span>
            <p class="mt-0.5 text-display-sm text-primary" data-result-total-bf>0 BF</p>
          </div>
          <div class="text-center">
            <span class="text-caption text-secondary">Total Cost</span>
            <p class="mt-0.5 text-display-sm text-primary" data-result-cost>$0.00</p>
          </div>
        </div>
        <p class="mt-1.5 text-center text-caption text-muted">
          Cost = Total BF &times; Price / BF &nbsp;&middot;&nbsp; Waste factor applied to cut list totals
        </p>
      </Card>
    </div>

    <!-- Lumber Preview — Column 2 -->
    <div>
      <Card class="h-full flex flex-col">
        <h3 class="mb-4 text-display-sm text-primary">Lumber Preview</h3>
        <div class="flex flex-1 items-center justify-center" data-visualizer-root>
          <div class="visualizer-scene" data-visualizer-scene>
            <div class="visualizer-box" data-visualizer-box>
              <div class="visualizer-face visualizer-face-front" data-face="front">
                <span data-face-label="front"></span>
              </div>
              <div class="visualizer-face visualizer-face-top" data-face="top">
                <span data-face-label="top"></span>
              </div>
              <div class="visualizer-face visualizer-face-side" data-face="side">
                <span data-face-label="side"></span>
              </div>
            </div>
          </div>
        </div>
        <p class="mt-3 text-center text-caption text-muted">
          Rough proportional representation
        </p>
      </Card>
    </div>

    <!-- Project Cut List — Full width below -->
    <div class="cut-list-section" data-cutlist-root>
      <Card class="flex flex-col">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
          <h3 class="text-display-sm text-primary">Project Cut List</h3>
          <div class="flex flex-wrap items-center gap-3 sm:gap-4">
            <span class="text-body-sm text-secondary" data-total-summary-bf>Total: 0 BF</span>
            <span class="text-body-sm text-secondary" data-total-summary-cost>Cost: $0.00</span>
            <button
              data-action="clear-all"
              class="linear-card px-3 py-1.5 text-body-sm text-secondary transition-colors hover:bg-secondary cursor-pointer"
            >
              Clear All
            </button>
          </div>
        </div>

        <div>
          <div
            class="flex flex-col items-center justify-center linear-card px-6 py-12 text-center"
            data-empty-state
          >
            <svg class="mb-3 h-8 w-8 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
            <p class="text-body-md text-muted">No items yet.</p>
            <p class="mt-1 text-body-sm text-muted">Add boards above to build your cut list.</p>
          </div>

          <div class="hidden overflow-x-auto linear-card" data-table-wrapper>
            <table class="w-full text-left text-body-sm">
              <thead>
                <tr class="border-b border-subtle bg-secondary">
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">Thickness</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">Width</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">Length</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">Qty</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">BF</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">Cost</th>
                  <th class="px-4 py-3"></th>
                </tr>
              </thead>
              <tbody data-table-body></tbody>
            </table>
          </div>
        </div>
      </Card>
    </div>
  </div>

  <!-- Waste Factor -->
  <div class="mx-auto mt-6 max-w-xl">
    <Card>
      <div class="flex items-center justify-between">
        <label class="text-body-sm-strong text-secondary" for="waste-slider">
          Waste Factor
        </label>
        <span class="font-mono text-body-md text-primary" data-waste-value>5%</span>
      </div>
      <input
        id="waste-slider"
        data-input="waste"
        type="range"
        min="0"
        max="50"
        value="5"
        step="1"
        class="mt-2 block w-full cursor-pointer accent-accent-mustard"
      />
      <div class="mt-1 flex justify-between text-caption text-muted">
        <span>0%</span>
        <span>50%</span>
      </div>
    </Card>
  </div>
</section>

<style>
  .visualizer-scene {
    width: 200px; height: 200px;
    perspective: 600px;
    display: flex; align-items: center; justify-content: center;
  }
  .visualizer-box {
    width: 120px; height: 80px;
    position: relative;
    transform-style: preserve-3d;
    transform: rotateX(-24deg) rotateY(-30deg);
    transition: transform 0.3s ease;
  }
  .visualizer-face {
    position: absolute;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--border-subtle);
    backface-visibility: hidden; overflow: hidden;
  }
  .visualizer-face span {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10px; color: var(--text-secondary);
    text-align: center; line-height: 1.2; pointer-events: none;
  }
  .visualizer-face-front { width: 120px; height: 60px; background: var(--bg-secondary); transform: translateZ(10px); }
  .visualizer-face-top { width: 120px; height: 20px; background: var(--bg-primary); transform: rotateX(90deg) translateZ(10px); transform-origin: bottom center; }
  .visualizer-face-side { width: 20px; height: 60px; background: var(--bg-primary); transform: rotateY(-90deg) translateZ(10px); transform-origin: right center; right: 0; }
</style>

<script>
  (() => {
    const STORAGE_KEY = "bfc_cutlist";

    const state = { unit: "imperial", waste: 5, cutList: [] };

    const $ = (s) => document.querySelector(s);
    const $$ = (s) => document.querySelectorAll(s);

    const root = $("[data-calculator-root]");
    if (!root) return;

    const inputs = {
      thickness: $("[data-input='thickness']"),
      width: $("[data-input='width']"),
      length: $("[data-input='length']"),
      quantity: $("[data-input='quantity']"),
      price: $("[data-input='price']"),
      waste: $("[data-input='waste']"),
    };

    const ui = {
      toggle: $("[data-unit-toggle]"),
      dot: $("[data-toggle-dot]"),
      labels: $("[data-unit-labels]"),
      thickness: $("[data-unit-label='thickness']"),
      width: $("[data-unit-label='width']"),
      length: $("[data-unit-label='length']"),
      price: $("[data-unit-label='price']"),
      bf: $("[data-result-bf]"),
      totalBf: $("[data-result-total-bf]"),
      cost: $("[data-result-cost]"),
      waste: $("[data-waste-value]"),
      presets: $("[data-presets-list]"),
      add: $("[data-action='add-to-cart']"),
      clear: $("[data-action='clear-all']"),
      empty: $("[data-empty-state]"),
      table: $("[data-table-wrapper]"),
      body: $("[data-table-body]"),
      summaryBf: $("[data-total-summary-bf]"),
      summaryCost: $("[data-total-summary-cost]"),
    };

    const vis = { box: $("[data-visualizer-box]") };
    if (vis.box) {
      vis.front = vis.box.querySelector("[data-face='front'] span");
      vis.top = vis.box.querySelector("[data-face='top'] span");
      vis.side = vis.box.querySelector("[data-face='side'] span");
    }

    function bf(t, w, l) {
      if (state.unit === "metric") { t/=25.4; w/=25.4; l/=0.3048; }
      return t*w*l/12;
    }
    const fmt = (v) => "$"+v.toFixed(2);
    const fmtBf = (v) => v.toFixed(2)+" BF";

    function labels() {
      const imp = state.unit === "imperial";
      ui.labels.textContent = imp ? "in / ft" : "mm / m";
      if (ui.thickness) ui.thickness.textContent = imp ? "in" : "mm";
      if (ui.width) ui.width.textContent = imp ? "in" : "mm";
      if (ui.length) ui.length.textContent = imp ? "ft" : "m";
      if (ui.price) ui.price.textContent = "$/BF";
      ui.dot.style.transform = imp ? "translateX(0.125rem)" : "translateX(1rem)";
    }

    function live() {
      const t = +inputs.thickness.value||0, w = +inputs.width.value||0, l = +inputs.length.value||0;
      const q = +inputs.quantity.value||1, p = +inputs.price.value||0;
      const per = bf(t,w,l);
      const totalBf = per * q;
      ui.bf.textContent = fmtBf(per);
      ui.totalBf.textContent = fmtBf(totalBf);
      ui.cost.textContent = fmt(totalBf * p);
    }

    function viz() {
      let t = +inputs.thickness.value||1, w = +inputs.width.value||1, l = +inputs.length.value||1;
      if (state.unit === "metric") { t/=25.4; w/=25.4; l/=0.3048; }
      const max = Math.max(t,w,l);
      if (max===0) return;
      const s = 100/max;
      const bw = Math.max(20,Math.min(140,w*s*1.2));
      const bh = Math.max(12,Math.min(80,l*s*1.2));
      const bd = Math.max(6,Math.min(40,t*s*1.2));
      if (!vis.box) return;
      vis.box.style.width = bw+"px"; vis.box.style.height = bh+"px";
      const f = vis.box.querySelector("[data-face='front']");
      const tp = vis.box.querySelector("[data-face='top']");
      const sd = vis.box.querySelector("[data-face='side']");
      if (f) { f.style.width=bw+"px"; f.style.height=bh+"px"; f.style.transform="translateZ("+(bd/2)+"px)"; }
      if (tp) { tp.style.width=bw+"px"; tp.style.height=bd+"px"; tp.style.transform="rotateX(90deg) translateZ("+(bd/2)+"px)"; }
      if (sd) { sd.style.width=bd+"px"; sd.style.height=bh+"px"; sd.style.transform="rotateY(-90deg) translateZ("+(bd/2)+"px)"; }
      const u = state.unit==="imperial"?"in":"mm", lu = state.unit==="imperial"?"ft":"m";
      if (vis.front) vis.front.textContent = t.toFixed(1)+"\u00D7"+w.toFixed(1)+" "+u;
      if (vis.top) vis.top.textContent = l.toFixed(1)+" "+lu;
      if (vis.side) vis.side.textContent = t.toFixed(1)+" "+u;
    }

    function save() { try { localStorage.setItem(STORAGE_KEY,JSON.stringify(state.cutList)); } catch(e) {} }
    function load() { try { const d=localStorage.getItem(STORAGE_KEY); if(d) state.cutList=JSON.parse(d); } catch(e) {} }

    function render() {
      const items = state.cutList;
      if (!items.length) {
        ui.empty.classList.remove("hidden"); ui.table.classList.add("hidden");
        tot(); return;
      }
      ui.empty.classList.add("hidden"); ui.table.classList.remove("hidden");
      const ul = state.unit==="imperial"?"in":"mm", ll = state.unit==="imperial"?"ft":"m";
      ui.body.innerHTML = items.map((it,i) =>
        `<tr class="border-b border-subtle transition-colors hover:bg-secondary">
          <td class="px-4 py-3 text-body-sm text-primary">${it.t.toFixed(2)} ${ul}</td>
          <td class="px-4 py-3 text-body-sm text-primary">${it.w.toFixed(2)} ${ul}</td>
          <td class="px-4 py-3 text-body-sm text-primary">${it.l.toFixed(2)} ${ll}</td>
          <td class="px-4 py-3 text-body-sm text-primary">${it.q}</td>
          <td class="px-4 py-3 font-mono text-body-sm text-primary">${it.bf.toFixed(2)} BF</td>
          <td class="px-4 py-3 font-mono text-body-sm text-primary">${fmt(it.c)}</td>
          <td class="px-4 py-3 text-right">
            <button data-remove="${i}" class="linear-card px-2 py-1 text-body-sm text-muted transition-colors hover:bg-secondary cursor-pointer">Remove</button>
          </td>
        </tr>`
      ).join("");
      ui.body.querySelectorAll("[data-remove]").forEach(b=>b.addEventListener("click",()=>{
        state.cutList.splice(+b.dataset.remove,1); save(); render(); tot();
      }));
      tot();
    }

    function tot() {
      const items = state.cutList;
      if (!items.length) { ui.summaryBf.textContent="Total: 0 BF"; ui.summaryCost.textContent="Cost: $0.00"; return; }
      let bs=0, cs=0;
      for (const it of items) { bs+=it.bf; cs+=it.c; }
      const m = 1+state.waste/100;
      ui.summaryBf.textContent = `Total: ${(bs*m).toFixed(2)} BF (incl. ${state.waste}% waste)`;
      ui.summaryCost.textContent = `Cost: ${fmt(cs*m)}`;
    }

    function add() {
      const t=+inputs.thickness.value||0, w=+inputs.width.value||0, l=+inputs.length.value||0;
      const q=+inputs.quantity.value||1, p=+inputs.price.value||0;
      if (t<=0||w<=0||l<=0) return;
      const per = bf(t,w,l);
      state.cutList.push({t,w,l,q,bf:per*q,c:per*q*p});
      save(); render(); tot();
    }

    function clearAll() { if (!state.cutList.length) return; state.cutList=[]; save(); render(); }

    function toggleUnit() {
      const nu = state.unit==="imperial"?"metric":"imperial";
      const t=+inputs.thickness.value||1.5, w=+inputs.width.value||3.5, l=+inputs.length.value||8;
      if (nu==="metric") {
        inputs.thickness.value=(t*25.4).toFixed(1); inputs.width.value=(w*25.4).toFixed(1); inputs.length.value=(l*0.3048).toFixed(2);
      } else {
        inputs.thickness.value=(t/25.4).toFixed(2); inputs.width.value=(w/25.4).toFixed(2); inputs.length.value=(l/0.3048).toFixed(2);
      }
      state.unit=nu; ui.toggle.setAttribute("aria-checked",nu==="metric");
      labels(); live(); viz();
    }

    function preset(v) {
      const p=v.split(","); if (p.length<3) return;
      let t=+p[0], w=+p[1], l=+p[2];
      if (state.unit==="metric") { t*=25.4; w*=25.4; l*=0.3048; }
      inputs.thickness.value=t; inputs.width.value=w; inputs.length.value=l;
      live(); viz();
    }

    function init() {
      load();
      Object.values(inputs).forEach(el=>{ if(!el) return; el.addEventListener("input",()=>{
        if(el===inputs.waste){ state.waste=+el.value||5; ui.waste.textContent=state.waste+"%"; tot(); return; }
        live(); viz();
      })});
      ui.toggle.addEventListener("click",toggleUnit);
      if (ui.presets) ui.presets.addEventListener("click",e=>{ const b=e.target.closest("[data-preset]"); if(b) preset(b.dataset.preset); });
      ui.add.addEventListener("click",add);
      Object.values(inputs).forEach(el=>{ if(!el||el===inputs.waste) return; el.addEventListener("keydown",e=>{ if(e.key==="Enter") add(); }); });
      ui.clear.addEventListener("click",clearAll);
      labels(); live(); viz(); render();
      if (ui.waste) ui.waste.textContent=state.waste+"%";
    }

    if (document.readyState==="loading") document.addEventListener("DOMContentLoaded",init); else init();
  })();
</script>
