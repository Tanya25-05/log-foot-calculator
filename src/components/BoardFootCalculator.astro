---
import Card from "./Card.astro";
import InputField from "./InputField.astro";
---

<section
  id="calculator"
  class="mx-auto max-w-7xl px-8 py-12 sm:px-14 lg:px-24 lg:py-16"
  data-calculator-root
>
  <!-- Section Heading -->
  <div class="mb-10 text-center">
    <span class="inline-block rounded-full bg-secondary px-3 py-1 text-caption-mono font-mono uppercase tracking-wide text-muted" data-i18n="calc.badge">
      Free Online Tool
    </span>
    <h2 class="mt-4 text-display-xl text-primary text-balance" data-i18n="calc.heading">
      Board Foot Calculator.
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-body-lg text-secondary" data-i18n="calc.subtitle">
      Real-time lumber calculations with a visual preview and a project cut list that saves to your browser.
    </p>
  </div>

  <!-- Calculator Layout: 2-col top + full-width cut list below -->
  <div class="calculator-layout">

    <!-- Board Dimensions — Column 1 -->
    <div>
      <Card>
        <div class="mb-6">
          <h3 class="text-display-sm text-primary" data-i18n="calc.board_dimensions">Board Dimensions</h3>
        </div>

        <div class="mb-6" data-presets-root>
          <span class="mb-3 block text-body-sm-strong text-secondary uppercase tracking-wide" data-i18n="calc.quick_fill">Quick Fill</span>
          <div class="flex flex-wrap gap-2" data-presets-list>
            <button data-preset="1.5,3.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×4 — 8'</button>
            <button data-preset="1.5,3.5,10" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×4 — 10'</button>
            <button data-preset="1.5,5.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×6 — 8'</button>
            <button data-preset="1.5,7.25,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×8 — 8'</button>
            <button data-preset="3.5,3.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">4×4 — 8'</button>
            <button data-preset="0.75,5.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">1×6 — 8'</button>
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <div>
            <label class="mb-1.5 block text-body-sm text-secondary" data-i18n="calc.thickness">Thickness</label>
            <div class="flex items-center rounded-lg border border-subtle bg-primary">
              <div data-input-wrapper="thickness" class="flex-1 flex items-center min-w-0">
                <input data-inp type="number" step="any" min="0" value="1.5" class="flex-1 min-w-0 border-none bg-transparent outline-none px-3 py-1.5 text-body-md text-primary [appearance:textfield]" />
              </div>
              <select data-unit="thickness" class="shrink-0 border-0 border-l border-subtle bg-transparent outline-none text-accent-mustard text-body-sm cursor-pointer px-2 py-1.5 max-sm:text-[11px] max-sm:px-1 max-sm:max-w-[68px]">
                <option value="mm">mm (millimeters)</option>
                <option value="cm">cm (centimeters)</option>
                <option value="in">in (inches)</option>
                <option value="ft">ft (feet)</option>
                <option value="m">m (meters)</option>
                <option disabled class="border-t border-subtle">──────────</option>
                <option value="ft_in">ft + in</option>
                <option value="m_cm">m + cm</option>
              </select>
            </div>
          </div>
          <div>
            <label class="mb-1.5 block text-body-sm text-secondary" data-i18n="calc.width">Width</label>
            <div class="flex items-center rounded-lg border border-subtle bg-primary">
              <div data-input-wrapper="width" class="flex-1 flex items-center min-w-0">
                <input data-inp type="number" step="any" min="0" value="3.5" class="flex-1 min-w-0 border-none bg-transparent outline-none px-3 py-1.5 text-body-md text-primary [appearance:textfield]" />
              </div>
              <select data-unit="width" class="shrink-0 border-0 border-l border-subtle bg-transparent outline-none text-accent-mustard text-body-sm cursor-pointer px-2 py-1.5 max-sm:text-[11px] max-sm:px-1 max-sm:max-w-[68px]">
                <option value="mm">mm (millimeters)</option>
                <option value="cm">cm (centimeters)</option>
                <option value="in">in (inches)</option>
                <option value="ft">ft (feet)</option>
                <option value="m">m (meters)</option>
                <option disabled class="border-t border-subtle">──────────</option>
                <option value="ft_in">ft + in</option>
                <option value="m_cm">m + cm</option>
              </select>
            </div>
          </div>
          <div>
            <label class="mb-1.5 block text-body-sm text-secondary" data-i18n="calc.length">Length</label>
            <div class="flex items-center rounded-lg border border-subtle bg-primary">
              <div data-input-wrapper="length" class="flex-1 flex items-center min-w-0">
                <input data-inp type="number" step="any" min="0" value="8" class="flex-1 min-w-0 border-none bg-transparent outline-none px-3 py-1.5 text-body-md text-primary [appearance:textfield]" />
              </div>
              <select data-unit="length" class="shrink-0 border-0 border-l border-subtle bg-transparent outline-none text-accent-mustard text-body-sm cursor-pointer px-2 py-1.5 max-sm:text-[11px] max-sm:px-1 max-sm:max-w-[68px]">
                <option value="mm">mm (millimeters)</option>
                <option value="cm">cm (centimeters)</option>
                <option value="in">in (inches)</option>
                <option value="ft">ft (feet)</option>
                <option value="m">m (meters)</option>
                <option disabled class="border-t border-subtle">──────────</option>
                <option value="ft_in">ft + in</option>
                <option value="m_cm">m + cm</option>
              </select>
            </div>
          </div>
          <div>
            <label class="mb-1.5 block text-body-sm text-secondary" data-i18n="calc.quantity">Quantity</label>
            <input data-input="quantity" type="number" step="1" min="1" value="1" class="w-full rounded-lg border border-subtle bg-primary px-3 py-1.5 text-body-md text-primary outline-none transition-colors focus:border-accent-mustard focus:ring-1 focus:ring-accent-mustard/40 [appearance:textfield]" />
          </div>
        </div>

        <div class="mt-6 grid grid-cols-2 gap-x-4 sm:grid-cols-4">
          <div class="sm:col-span-2">
            <label class="mb-1.5 block text-body-sm text-secondary">
              <span data-i18n="calc.price_per_bf">Price / BF</span>
              <span class="text-muted" data-unit-label="price">$/BF</span>
            </label>
            <div class="flex gap-2">
              <select data-currency class="shrink-0 rounded-lg border border-subtle bg-primary px-2.5 py-1.5 text-body-sm text-primary outline-none transition-colors focus:border-accent-mustard focus:ring-1 focus:ring-accent-mustard/40 cursor-pointer">
                <option value="USD">$ USD</option>
                <option value="EUR">€ EUR</option>
                <option value="GBP">£ GBP</option>
                <option value="CAD">C$ CAD</option>
                <option value="AUD">A$ AUD</option>
                <option value="JPY">¥ JPY</option>
                <option value="CNY">¥ CNY</option>
                <option value="INR">₹ INR</option>
                <option value="BRL">R$ BRL</option>
                <option value="MXN">$ MXN</option>
              </select>
              <div class="relative flex-1">
                <input
                  data-input="price"
                  type="number"
                  step="0.01"
                  min="0"
                  value="0"
                  class="w-full rounded-lg border border-subtle bg-primary px-3 py-1.5 text-body-md text-primary outline-none transition-colors focus:border-accent-mustard focus:ring-1 focus:ring-accent-mustard/40"
                />

              </div>
            </div>
          </div>
          <div class="flex items-end sm:col-span-2 sm:justify-end">
            <button
              data-action="add-to-cart"
              class="w-full rounded-lg bg-accent-mustard px-4 py-2.5 text-body-md-strong text-white transition-opacity hover:opacity-90 cursor-pointer" data-i18n="calc.add_to_cut_list"
            >
              Add to Cut List
            </button>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-3 gap-4 rounded-lg bg-secondary p-4">
          <div class="text-center">
            <span class="text-caption text-secondary inline-flex items-center justify-center gap-1">
              <span data-i18n="calc.per_board">Per Board</span>
              <span class="group relative inline-flex items-center justify-center cursor-help" tabindex="0">
                <svg class="h-3.5 w-3.5 text-muted" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="8" cy="8" r="6.5"/>
                  <text x="8" y="10.5" text-anchor="middle" font-size="9" font-style="italic" font-family="serif" fill="currentColor" stroke="none">i</text>
                </svg>
                <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 hidden group-hover:block group-focus:block w-44 rounded-lg border border-subtle bg-primary px-2.5 py-1.5 text-caption text-secondary shadow-card z-10 pointer-events-none">Board feet for one board at the entered dimensions.</span>
              </span>
            </span>
            <p class="mt-0.5 text-display-sm text-primary" data-result-bf>0 BF</p>
          </div>
          <div class="text-center">
            <span class="text-caption text-secondary inline-flex items-center justify-center gap-1">
              <span data-i18n="calc.total_bf">Total BF</span>
              <span class="group relative inline-flex items-center justify-center cursor-help" tabindex="0">
                <svg class="h-3.5 w-3.5 text-muted" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="8" cy="8" r="6.5"/>
                  <text x="8" y="10.5" text-anchor="middle" font-size="9" font-style="italic" font-family="serif" fill="currentColor" stroke="none">i</text>
                </svg>
                <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 hidden group-hover:block group-focus:block w-44 rounded-lg border border-subtle bg-primary px-2.5 py-1.5 text-caption text-secondary shadow-card z-10 pointer-events-none">Total board feet across all boards times their quantity.</span>
              </span>
            </span>
            <p class="mt-0.5 text-display-sm text-primary" data-result-total-bf>0 BF</p>
          </div>
          <div class="text-center">
            <span class="text-caption text-secondary inline-flex items-center justify-center gap-1">
              <span data-i18n="calc.total_cost">Total Cost</span>
              <span class="group relative inline-flex items-center justify-center cursor-help" tabindex="0">
                <svg class="h-3.5 w-3.5 text-muted" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="8" cy="8" r="6.5"/>
                  <text x="8" y="10.5" text-anchor="middle" font-size="9" font-style="italic" font-family="serif" fill="currentColor" stroke="none">i</text>
                </svg>
                <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1.5 hidden group-hover:block group-focus:block w-44 rounded-lg border border-subtle bg-primary px-2.5 py-1.5 text-caption text-secondary shadow-card z-10 pointer-events-none">Total board feet × price per board foot.</span>
              </span>
            </span>
            <p class="mt-0.5 text-display-sm text-primary" data-result-cost>$0.00</p>
          </div>
        </div>
        <p class="mt-1.5 text-center text-caption text-muted" data-i18n="calc.cost_formula">
          Cost = Total BF &times; Price / BF &nbsp;&middot;&nbsp; Waste factor applied to cut list totals
        </p>
      </Card>
    </div>

    <!-- Lumber Preview — Column 2 -->
    <div class="flex flex-col gap-6">
      <Card class="flex flex-col">
        <h3 class="mb-4 text-display-sm text-primary" data-i18n="calc.lumber_preview">Lumber Preview</h3>
        <div class="flex flex-1 items-center justify-center" data-visualizer-root>
          <svg class="w-full h-auto max-w-full" viewBox="0 0 260 200" fill="none" xmlns="http://www.w3.org/2000/svg" data-visualizer-svg>
            <!-- Side face (back) -->
            <polygon data-viz="side" fill="var(--bg-primary)" stroke="var(--border-subtle)" stroke-width="1.2" stroke-linejoin="round" />
            <!-- Top face -->
            <polygon data-viz="top" fill="var(--bg-secondary)" stroke="var(--border-subtle)" stroke-width="1.2" stroke-linejoin="round" />
            <!-- Front face (front) -->
            <polygon data-viz="front" fill="var(--bg-primary)" stroke="var(--border-subtle)" stroke-width="1.2" stroke-linejoin="round" />

            <!-- Dimension labels -->
            <text data-viz="label-w" font-size="9" fill="var(--text-secondary)" text-anchor="middle" font-family="var(--font-mono)" font-weight="500" />
            <text data-viz="label-l" font-size="9" fill="var(--text-secondary)" text-anchor="end" font-family="var(--font-mono)" font-weight="500" />
            <text data-viz="label-t" font-size="9" fill="var(--text-secondary)" text-anchor="middle" font-family="var(--font-mono)" font-weight="500" />

            <!-- Dimension indicator icons -->
            <line data-viz="dimline-w" stroke="var(--accent-mustard)" stroke-width="1.5" stroke-linecap="round" />
            <line data-viz="dimline-l" stroke="var(--accent-mustard)" stroke-width="1.5" stroke-linecap="round" />
            <line data-viz="dimline-t" stroke="var(--accent-mustard)" stroke-width="1.5" stroke-linecap="round" />
            <circle data-viz="dot-w1" r="2.5" fill="var(--accent-mustard)" />
            <circle data-viz="dot-w2" r="2.5" fill="var(--accent-mustard)" />
            <circle data-viz="dot-l1" r="2.5" fill="var(--accent-mustard)" />
            <circle data-viz="dot-l2" r="2.5" fill="var(--accent-mustard)" />
            <circle data-viz="dot-t1" r="2.5" fill="var(--accent-mustard)" />
            <circle data-viz="dot-t2" r="2.5" fill="var(--accent-mustard)" />
          </svg>
        </div>
        <p class="mt-3 text-center text-caption text-secondary leading-relaxed px-2">
          <strong>Quickly calculate board feet</strong>, visualize lumber dimensions, and <strong>manage your project cut list</strong> — all in one place. Enter thickness, width, and length, choose your units, set a price, and get <strong>instant cost estimates</strong>. Add multiple boards to build a cut list that <strong>auto-saves to your browser</strong>.
        </p>
      </Card>

      <p class="text-body-md text-secondary leading-relaxed md:mt-auto">
        A <strong>board foot calculator</strong> is an essential tool for anyone working with lumber — from professional contractors and cabinet makers to weekend DIYers. Board footage is the standard unit of volume for hardwood lumber in North America, and getting it right means the difference between a profitable project and costly waste. Our <strong>lumber board foot calculator</strong> delivers fast, accurate results with a clean interface and zero clutter.
      </p>
    </div>

    <!-- Project Cut List — Full width below -->
    <div class="cut-list-section" data-cutlist-root>
      <Card class="flex flex-col">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
          <h3 class="text-display-sm text-primary" data-i18n="calc.project_cut_list">Project Cut List</h3>
          <div class="flex flex-wrap items-center gap-3 sm:gap-4">
            <span class="text-body-sm text-secondary" data-total-summary-bf>Total: 0 BF</span>
            <span class="text-body-sm text-secondary" data-total-summary-cost>Cost: $0.00</span>
            <button
              data-action="export-pdf"
              class="linear-card px-3 py-1.5 text-body-sm text-secondary transition-colors hover:bg-secondary cursor-pointer"
            >
              Save PDF
            </button>
            <button
              data-action="export-img"
              class="linear-card px-3 py-1.5 text-body-sm text-secondary transition-colors hover:bg-secondary cursor-pointer"
            >
              Save Image
            </button>
            <button
              data-action="clear-all"
              class="linear-card px-3 py-1.5 text-body-sm text-secondary transition-colors hover:bg-secondary cursor-pointer" data-i18n="calc.clear_all"
            >
              Clear All
            </button>
          </div>
        </div>

        <div>
          <div
            class="flex flex-col items-center justify-center linear-card px-6 py-12 text-center"
            data-empty-state
          >
            <svg class="mb-3 h-8 w-8 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
            <p class="text-body-md text-muted" data-i18n="calc.empty_title">No items yet.</p>
            <p class="mt-1 text-body-sm text-muted" data-i18n="calc.empty_desc">Add boards above to build your cut list.</p>
          </div>

          <div class="hidden overflow-x-auto linear-card" data-table-wrapper>
            <table class="w-full text-left text-body-sm">
              <thead>
                <tr class="border-b border-subtle bg-secondary">
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted" data-i18n="calc.thickness">Thickness</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted" data-i18n="calc.width">Width</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted" data-i18n="calc.length">Length</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted" data-i18n="calc.quantity">Qty</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">BF</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted" data-i18n="calc.cost_label">Cost</th>
                  <th class="px-4 py-3"></th>
                </tr>
              </thead>
              <tbody data-table-body></tbody>
            </table>
          </div>
        </div>
      </Card>
    </div>
  </div>

  <!-- Waste Factor -->
  <div class="mx-auto mt-6 max-w-xl">
    <Card>
      <div class="flex items-center justify-between">
        <label class="text-body-sm-strong text-secondary" for="waste-slider" data-i18n="calc.waste_factor">
          Waste Factor
        </label>
        <span class="font-mono text-body-md text-primary" data-waste-value>5%</span>
      </div>
      <input
        id="waste-slider"
        data-input="waste"
        type="range"
        min="0"
        max="50"
        value="5"
        step="1"
        class="mt-2 block w-full cursor-pointer accent-accent-mustard"
      />
      <div class="mt-1 flex justify-between text-caption text-muted">
        <span>0%</span>
        <span>50%</span>
      </div>
    </Card>
  </div>
</section>

<style>
  [data-visualizer-svg] text {
    user-select: none;
    pointer-events: none;
  }

  @media print {
    body * { visibility: hidden; }
    [data-cutlist-root], [data-cutlist-root] * { visibility: visible; }
    [data-cutlist-root] { position: absolute; left: 0; top: 0; width: 100%; }
    [data-cutlist-root] [data-action="export-pdf"],
    [data-cutlist-root] [data-action="export-img"],
    [data-cutlist-root] [data-action="clear-all"] { display: none !important; }
  }
</style>

<script>
  (() => {
    const STORAGE_KEY = "bfc_cutlist";
    const CURRENCIES = { USD:"$", EUR:"€", GBP:"£", CAD:"C$", AUD:"A$", JPY:"¥", CNY:"¥", INR:"₹", BRL:"R$", MXN:"$" };
    const state = { units: { thickness: "in", width: "in", length: "ft" }, waste: 5, cutList: [], currency: "USD" };

    const $ = s => document.querySelector(s);
    const $$ = s => document.querySelectorAll(s);
    const root = $("[data-calculator-root]");
    if (!root) return;

    const wrappers = {
      thickness: $("[data-input-wrapper='thickness']"),
      width: $("[data-input-wrapper='width']"),
      length: $("[data-input-wrapper='length']"),
    };

    const inputs = {
      quantity: $("[data-input='quantity']"),
      price: $("[data-input='price']"),
      waste: $("[data-input='waste']"),
      unitT: $("[data-unit='thickness']"),
      unitW: $("[data-unit='width']"),
      unitL: $("[data-unit='length']"),
    };

    const ui = {
      price: $("[data-unit-label='price']"),
      bf: $("[data-result-bf]"),
      totalBf: $("[data-result-total-bf]"),
      cost: $("[data-result-cost]"),
      waste: $("[data-waste-value]"),
      presets: $("[data-presets-list]"),
      add: $("[data-action='add-to-cart']"),
      clear: $("[data-action='clear-all']"),
      empty: $("[data-empty-state]"),
      table: $("[data-table-wrapper]"),
      body: $("[data-table-body]"),
      summaryBf: $("[data-total-summary-bf]"),
      summaryCost: $("[data-total-summary-cost]"),
      currency: $("[data-currency]"),
    };

    let vis = {};

    function inpVal(key, n) {
      const w = wrappers[key];
      if (!w) return 0;
      const el = n === 2 ? w.querySelector("[data-inp2]") : w.querySelector("[data-inp]");
      return +el?.value || 0;
    }

    function valIn(key) {
      const u = state.units[key], a = inpVal(key);
      if (u === "in") return a;
      if (u === "mm") return a / 25.4;
      if (u === "cm") return a / 2.54;
      if (u === "ft") return a * 12;
      if (u === "m") return a * 39.3701;
      if (u === "ft_in") return a * 12 + inpVal(key, 2);
      if (u === "m_cm") return a * 39.3701 + inpVal(key, 2) / 2.54;
      return a;
    }

    function valFt() {
      const u = state.units.length, a = inpVal("length");
      if (u === "ft") return a;
      if (u === "in") return a / 12;
      if (u === "mm") return a / 304.8;
      if (u === "cm") return a / 30.48;
      if (u === "m") return a / 0.3048;
      if (u === "ft_in") return a + inpVal("length", 2) / 12;
      if (u === "m_cm") return a / 0.3048 + inpVal("length", 2) / 30.48;
      return a;
    }
    function bf() { return valIn("thickness") * valIn("width") * valFt() / 12; }

    const sym = () => CURRENCIES[state.currency] || "$";
    const fmt = v => sym() + v.toFixed(2);
    const fmtBf = v => v.toFixed(2) + " BF";

    function labels() {
      if (ui.price) ui.price.textContent = sym() + "/BF";
    }

    function live() {
      const q = +inputs.quantity.value || 1, p = +inputs.price.value || 0;
      const per = bf(), totalBf = per * q;
      ui.bf.textContent = fmtBf(per);
      ui.totalBf.textContent = fmtBf(totalBf);
      ui.cost.textContent = fmt(totalBf * p);
    }

    function initVis() {
      vis = {
        front: $("[data-viz='front']"), top: $("[data-viz='top']"), side: $("[data-viz='side']"),
        labelW: $("[data-viz='label-w']"), labelL: $("[data-viz='label-l']"), labelT: $("[data-viz='label-t']"),
        dimlineW: $("[data-viz='dimline-w']"), dimlineL: $("[data-viz='dimline-l']"), dimlineT: $("[data-viz='dimline-t']"),
        dotW1: $("[data-viz='dot-w1']"), dotW2: $("[data-viz='dot-w2']"),
        dotL1: $("[data-viz='dot-l1']"), dotL2: $("[data-viz='dot-l2']"),
        dotT1: $("[data-viz='dot-t1']"), dotT2: $("[data-viz='dot-t2']"),
      };
    }

    function unitAbbr(key) {
      const m = { mm:"mm", cm:"cm", in:"in", ft:"ft", m:"m", ft_in:"ft+in", m_cm:"m+cm" };
      return m[state.units[key]] || state.units[key];
    }

    function dimDisplay(totInches, key) {
      const u = state.units[key];
      if (u === "ft_in") return Math.floor(totInches / 12) + "' " + (totInches % 12).toFixed(1) + '"';
      if (u === "m_cm") { const t = totInches * 2.54; return Math.floor(t / 100) + " m " + (t % 100).toFixed(1) + " cm"; }
      if (u === "in") return totInches.toFixed(2) + " in";
      if (u === "mm") return (totInches * 25.4).toFixed(1) + " mm";
      if (u === "cm") return (totInches * 2.54).toFixed(2) + " cm";
      if (u === "ft") return (totInches / 12).toFixed(3) + " ft";
      if (u === "m") return (totInches / 39.3701).toFixed(3) + " m";
      return totInches.toFixed(2);
    }

    function rebuildInput(key, totIn) {
      const w = wrappers[key];
      if (!w) return;
      const u = state.units[key];
      let val1 = Math.max(0, totIn != null ? +totIn : +w.querySelector("[data-inp]")?.value || 0);
      let val2 = 0;

      if (u === "ft_in") {
        const inches = Math.max(0, totIn != null ? +totIn : 0);
        val1 = Math.floor(inches / 12);
        val2 = +(inches - val1 * 12).toFixed(1);
      } else if (u === "m_cm") {
        const cm = Math.max(0, (totIn != null ? +totIn : 0) * 2.54);
        val1 = Math.floor(cm / 100);
        val2 = +(cm - val1 * 100).toFixed(1);
      } else if (u === "in") {
        val1 = +val1.toFixed(2);
      } else if (u === "mm") {
        val1 = +(val1 * 25.4).toFixed(1);
      } else if (u === "cm") {
        val1 = +(val1 * 2.54).toFixed(2);
      } else if (u === "ft") {
        val1 = +(val1 / 12).toFixed(3);
      } else if (u === "m") {
        val1 = +(val1 / 39.3701).toFixed(3);
      }

      if (u === "ft_in" || u === "m_cm") {
        const p1 = u === "ft_in" ? "ft" : "m";
        const p2 = u === "ft_in" ? "in" : "cm";
        w.innerHTML = `<input data-inp type="number" step="any" min="0" value="${val1}" class="flex-1 min-w-0 border-none bg-transparent outline-none px-2 py-1.5 text-body-md text-primary [appearance:textfield]" placeholder="${p1}" /><div class="w-px self-stretch bg-[var(--border-subtle)] shrink-0"></div><input data-inp2 type="number" step="any" min="0" value="${val2}" class="flex-1 min-w-0 border-none bg-transparent outline-none px-2 py-1.5 text-body-md text-primary [appearance:textfield]" placeholder="${p2}" />`;
      } else {
        w.innerHTML = `<input data-inp type="number" step="any" min="0" value="${val1}" class="flex-1 min-w-0 border-none bg-transparent outline-none px-3 py-1.5 text-body-md text-primary [appearance:textfield]" />`;
      }
    }

    function toCanonical(key) {
      const w = wrappers[key];
      if (!w) return 0;
      const v1 = +w.querySelector("[data-inp]")?.value || 0;
      const v2 = +w.querySelector("[data-inp2]")?.value || 0;
      const u = state.units[key];
      if (key === "length") {
        if (u === "ft") return v1;
        if (u === "in") return v1 / 12;
        if (u === "mm") return v1 / 304.8;
        if (u === "cm") return v1 / 30.48;
        if (u === "m") return v1 / 0.3048;
        if (u === "ft_in") return v1 + v2 / 12;
        if (u === "m_cm") return v1 / 0.3048 + v2 / 30.48;
        return v1;
      }
      if (u === "in") return v1;
      if (u === "mm") return v1 / 25.4;
      if (u === "cm") return v1 / 2.54;
      if (u === "ft") return v1 * 12;
      if (u === "m") return v1 * 39.3701;
      if (u === "ft_in") return v1 * 12 + v2;
      if (u === "m_cm") return v1 * 39.3701 + v2 / 2.54;
      return v1;
    }

    function viz() {
      if (!vis.front) initVis();
      let t = valIn("thickness") || 1, w = valIn("width") || 1, l = valFt() || 1;
      const max = Math.max(t, w, l);
      if (max === 0) return;
      const scale = 54 / max;
      const sw = Math.max(28, Math.min(92, w * scale));
      const sl = Math.max(22, Math.min(72, l * scale));
      const st = Math.max(10, Math.min(38, t * scale));
      const ox = st * 0.48, oy = st * 0.28;
      const cx = 130, cy = 102;
      const pt = (x, y) => x.toFixed(1) + "," + y.toFixed(1);
      const p0 = [cx - sw/2, cy + sl/2], p1 = [cx + sw/2, cy + sl/2];
      const p2 = [cx + sw/2, cy - sl/2], p3 = [cx - sw/2, cy - sl/2];
      const p4 = [cx + sw/2 + ox, cy + sl/2 - oy], p5 = [cx + sw/2 + ox, cy - sl/2 - oy], p6 = [cx - sw/2 + ox, cy - sl/2 - oy];
      if (vis.side) vis.side.setAttribute("points", pt(p1[0],p1[1])+" "+pt(p4[0],p4[1])+" "+pt(p5[0],p5[1])+" "+pt(p2[0],p2[1]));
      if (vis.top) vis.top.setAttribute("points", pt(p3[0],p3[1])+" "+pt(p2[0],p2[1])+" "+pt(p5[0],p5[1])+" "+pt(p6[0],p6[1]));
      if (vis.front) vis.front.setAttribute("points", pt(p0[0],p0[1])+" "+pt(p1[0],p1[1])+" "+pt(p2[0],p2[1])+" "+pt(p3[0],p3[1]));
      if (vis.labelW) { vis.labelW.setAttribute("x", cx); vis.labelW.setAttribute("y", cy + sl/2 + 20); vis.labelW.textContent = dimDisplay(w, "width"); }
      if (vis.labelL) { vis.labelL.setAttribute("x", cx - sw/2 - 18); vis.labelL.setAttribute("y", cy + 4); vis.labelL.textContent = dimDisplay(l * 12, "length"); }
      if (vis.labelT) { vis.labelT.setAttribute("x", cx + sw/2 + ox/2); vis.labelT.setAttribute("y", cy - sl/2 - oy - 12); vis.labelT.textContent = dimDisplay(t, "thickness"); }
      if (vis.dimlineW) { vis.dimlineW.setAttribute("x1", p0[0]); vis.dimlineW.setAttribute("y1", p0[1]+8); vis.dimlineW.setAttribute("x2", p1[0]); vis.dimlineW.setAttribute("y2", p1[1]+8); }
      if (vis.dimlineL) { vis.dimlineL.setAttribute("x1", p3[0]-9); vis.dimlineL.setAttribute("y1", p3[1]); vis.dimlineL.setAttribute("x2", p0[0]-9); vis.dimlineL.setAttribute("y2", p0[1]); }
      if (vis.dimlineT) { vis.dimlineT.setAttribute("x1", p2[0]); vis.dimlineT.setAttribute("y1", p2[1]-6); vis.dimlineT.setAttribute("x2", p5[0]); vis.dimlineT.setAttribute("y2", p5[1]-6); }
      if (vis.dotW1) { vis.dotW1.setAttribute("cx", p0[0]); vis.dotW1.setAttribute("cy", p0[1]+8); }
      if (vis.dotW2) { vis.dotW2.setAttribute("cx", p1[0]); vis.dotW2.setAttribute("cy", p1[1]+8); }
      if (vis.dotL1) { vis.dotL1.setAttribute("cx", p3[0]-9); vis.dotL1.setAttribute("cy", p3[1]); }
      if (vis.dotL2) { vis.dotL2.setAttribute("cx", p0[0]-9); vis.dotL2.setAttribute("cy", p0[1]); }
      if (vis.dotT1) { vis.dotT1.setAttribute("cx", p2[0]); vis.dotT1.setAttribute("cy", p2[1]-6); }
      if (vis.dotT2) { vis.dotT2.setAttribute("cx", p5[0]); vis.dotT2.setAttribute("cy", p5[1]-6); }
    }

    function save() { try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state.cutList)); localStorage.setItem("bfc_currency", state.currency); } catch (e) {} }
    function load() { try { const d = localStorage.getItem(STORAGE_KEY); if (d) state.cutList = JSON.parse(d); const c = localStorage.getItem("bfc_currency"); if (c && CURRENCIES[c]) state.currency = c; } catch (e) {} }

    function render() {
      const items = state.cutList;
      if (!items.length) { ui.empty.classList.remove("hidden"); ui.table.classList.add("hidden"); tot(); return; }
      ui.empty.classList.add("hidden"); ui.table.classList.remove("hidden");
      ui.body.innerHTML = items.map((it, i) =>
        `<tr class="border-b border-subtle transition-colors hover:bg-secondary">
          <td class="px-4 py-3 text-body-sm text-primary">${dimDisplay(it.t, "thickness")}</td>
          <td class="px-4 py-3 text-body-sm text-primary">${dimDisplay(it.w, "width")}</td>
          <td class="px-4 py-3 text-body-sm text-primary">${dimDisplay(it.l * 12, "length")}</td>
          <td class="px-4 py-3 text-body-sm text-primary">${it.q}</td>
          <td class="px-4 py-3 font-mono text-body-sm text-primary">${it.bf.toFixed(2)} BF</td>
          <td class="px-4 py-3 font-mono text-body-sm text-primary">${fmt(it.c)}</td>
          <td class="px-4 py-3 text-right">
            <button data-remove="${i}" class="linear-card px-2 py-1 text-body-sm text-muted transition-colors hover:bg-secondary cursor-pointer">Remove</button>
          </td>
        </tr>`
      ).join("");
      ui.body.querySelectorAll("[data-remove]").forEach(b => b.addEventListener("click", () => { state.cutList.splice(+b.dataset.remove, 1); save(); render(); tot(); }));
      tot();
    }

    function tot() {
      const tl = window.i18n?.t("calc.total_label") || "Total:", cl = window.i18n?.t("calc.cost_label") || "Cost:";
      const items = state.cutList;
      if (!items.length) { ui.summaryBf.textContent = tl + " 0 BF"; ui.summaryCost.textContent = cl + " $0.00"; return; }
      let bs = 0, cs = 0;
      for (const it of items) { bs += it.bf; cs += it.c; }
      const m = 1 + state.waste / 100;
      ui.summaryBf.textContent = tl + ` ${(bs * m).toFixed(2)} BF (incl. ${state.waste}% waste)`;
      ui.summaryCost.textContent = cl + ` ${fmt(cs * m)}`;
    }

    function add() {
      const t = valIn("thickness"), w = valIn("width"), l = valFt();
      const q = +inputs.quantity.value || 1, p = +inputs.price.value || 0;
      if (t <= 0 || w <= 0 || l <= 0) return;
      const per = bf();
      state.cutList.push({ t, w, l, q, bf: per * q, c: per * q * p });
      save(); render(); tot();
    }

    function clearAll() { if (!state.cutList.length) return; state.cutList = []; save(); render(); }

    function exportPdf() { if (!state.cutList.length) return; window.print(); }

    function exportImg() {
      const items = state.cutList;
      if (!items.length) return;
      const cols = ["Thickness", "Width", "Length", "Qty", "BF", "Cost"];
      const rows = items.map(it => [
        dimDisplay(it.t, "thickness"), dimDisplay(it.w, "width"),
        dimDisplay(it.l * 12, "length"), it.q, it.bf.toFixed(2) + " BF",
        sym() + it.c.toFixed(2)
      ]);
      const m = 1 + state.waste / 100;
      let bs = 0, cs = 0;
      for (const it of items) { bs += it.bf; cs += it.c; }
      rows.push(["","","","","",""]);
      rows.push(["TOTAL", "", "", "", (bs * m).toFixed(2) + " BF", sym() + (cs * m).toFixed(2)]);
      const cw = 140, rh = 32, pad = 16, hdr = 44;
      const tw = cols.length * cw + pad * 2;
      const th = (rows.length + 1) * rh + hdr + pad * 2;
      const c = document.createElement("canvas");
      c.width = tw; c.height = th;
      const ctx = c.getContext("2d");
      ctx.fillStyle = "#FFFFFF"; ctx.fillRect(0, 0, tw, th);
      ctx.fillStyle = "#111111";
      ctx.font = "bold 13px Inter, sans-serif";
      cols.forEach((col, i) => { ctx.fillText(col, pad + i * cw + 8, pad + 18); });
      ctx.strokeStyle = "#E5E5E5"; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(pad, pad + hdr); ctx.lineTo(tw - pad, pad + hdr); ctx.stroke();
      ctx.font = "12px Inter, sans-serif";
      rows.forEach((row, ri) => {
        const yy = pad + hdr + 10 + (ri + 1) * rh;
        if (ri === rows.length - 1) { ctx.font = "bold 12px Inter, sans-serif"; }
        row.forEach((cell, ci) => { ctx.fillText(cell, pad + ci * cw + 8, yy); });
        ctx.font = "12px Inter, sans-serif";
        if (ri < rows.length - 1) {
          ctx.strokeStyle = "#F0F0F0"; ctx.lineWidth = 1;
          ctx.beginPath(); ctx.moveTo(pad, yy + rh - 22); ctx.lineTo(tw - pad, yy + rh - 22); ctx.stroke();
        }
      });
      const a = document.createElement("a");
      a.href = c.toDataURL("image/png");
      a.download = "cut-list.png";
      a.click();
    }

    function preset(v) {
      const p = v.split(",");
      if (p.length < 3) return;
      rebuildInput("thickness", +p[0]);
      rebuildInput("width", +p[1]);
      rebuildInput("length", +p[2] * 12);
      live(); viz();
    }

    function init() {
      load();
      initVis();
      const dims = [["thickness", "unitT"], ["width", "unitW"], ["length", "unitL"]];
      dims.forEach(([k, uk]) => {
        const sel = inputs[uk];
        if (!sel) return;
        sel.value = state.units[k];
        sel.addEventListener("change", () => {
          const oldUnit = state.units[k], newUnit = sel.value;
          if (oldUnit === newUnit) return;
          const canonical = k === "length" ? toCanonical("length") : toCanonical(k);
          state.units[k] = newUnit;
          rebuildInput(k, k === "length" ? canonical * 12 : canonical);
          labels(); live(); viz();
        });
      });
      dims.forEach(([k]) => rebuildInput(k));
      root.addEventListener("input", e => {
        if (e.target.closest("[data-input-wrapper]")) { live(); viz(); return; }
        if (e.target === inputs.waste) { state.waste = +e.target.value || 5; ui.waste.textContent = state.waste + "%"; tot(); return; }
        if (e.target === inputs.price || e.target === inputs.quantity) { live(); return; }
      });
      root.addEventListener("keydown", e => { if (e.key === "Enter" && e.target.closest("[data-input-wrapper]")) add(); });
      if (ui.presets) ui.presets.addEventListener("click", e => { const b = e.target.closest("[data-preset]"); if (b) preset(b.dataset.preset); });
      ui.add.addEventListener("click", add);
      ui.clear.addEventListener("click", clearAll);
      const pdfBtn = root.querySelector("[data-action='export-pdf']");
      const imgBtn = root.querySelector("[data-action='export-img']");
      if (pdfBtn) pdfBtn.addEventListener("click", exportPdf);
      if (imgBtn) imgBtn.addEventListener("click", exportImg);
      if (ui.currency) { ui.currency.value = state.currency; ui.currency.addEventListener("change", () => { state.currency = ui.currency.value; save(); labels(); live(); render(); }); }
      document.addEventListener("i18nchange", () => { labels(); tot(); });
      labels(); live(); viz(); render();
      if (ui.waste) ui.waste.textContent = state.waste + "%";
    }

    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init); else init();
  })();
</script>
