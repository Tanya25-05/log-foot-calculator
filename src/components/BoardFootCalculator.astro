---
import Card from "./Card.astro";
import InputField from "./InputField.astro";
---

<section
  id="calculator"
  class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16"
  data-calculator-root
>
  <!-- Section Heading -->
  <div class="mb-10 text-center">
    <span class="inline-block rounded-full bg-secondary px-3 py-1 text-caption-mono font-mono uppercase tracking-wide text-muted">
      Free Online Tool
    </span>
    <h2 class="mt-4 text-display-xl text-primary text-balance">
      Board Foot Calculator.
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-body-lg text-secondary">
      Real-time lumber calculations with a visual preview and a project cut list that saves to your browser.
    </p>
  </div>

  <!-- Calculator Layout: 2-col top + full-width cut list below -->
  <div class="calculator-layout">

    <!-- Board Dimensions — Column 1 -->
    <div>
      <Card>
        <div class="mb-6">
          <h3 class="text-display-sm text-primary">Board Dimensions</h3>
        </div>

        <div class="mb-6" data-presets-root>
          <span class="mb-3 block text-body-sm-strong text-secondary uppercase tracking-wide">Quick Fill</span>
          <div class="flex flex-wrap gap-2" data-presets-list>
            <button data-preset="1.5,3.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×4 — 8'</button>
            <button data-preset="1.5,3.5,10" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×4 — 10'</button>
            <button data-preset="1.5,5.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×6 — 8'</button>
            <button data-preset="1.5,7.25,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">2×8 — 8'</button>
            <button data-preset="3.5,3.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">4×4 — 8'</button>
            <button data-preset="0.75,5.5,8" class="linear-card px-3 py-1.5 text-body-sm text-primary transition-colors hover:bg-secondary cursor-pointer">1×6 — 8'</button>
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <div>
            <label class="mb-1.5 block text-body-sm text-secondary">Thickness</label>
            <div class="flex items-center rounded-lg border border-subtle bg-primary">
              <input data-input="thickness" type="number" step="0.25" min="0.1" value="1.5" class="flex-1 border-none bg-transparent outline-none px-3 py-2 text-body-md text-primary [appearance:textfield]" />
              <select data-unit="thickness" class="border-none bg-transparent outline-none text-accent-mustard text-body-sm cursor-pointer px-2 py-2">
                <option value="in">in</option>
                <option value="mm">mm</option>
              </select>
            </div>
          </div>
          <div>
            <label class="mb-1.5 block text-body-sm text-secondary">Width</label>
            <div class="flex items-center rounded-lg border border-subtle bg-primary">
              <input data-input="width" type="number" step="0.25" min="0.1" value="3.5" class="flex-1 border-none bg-transparent outline-none px-3 py-2 text-body-md text-primary [appearance:textfield]" />
              <select data-unit="width" class="border-none bg-transparent outline-none text-accent-mustard text-body-sm cursor-pointer px-2 py-2">
                <option value="in">in</option>
                <option value="mm">mm</option>
              </select>
            </div>
          </div>
          <div>
            <label class="mb-1.5 block text-body-sm text-secondary">Length</label>
            <div class="flex items-center rounded-lg border border-subtle bg-primary">
              <input data-input="length" type="number" step="0.5" min="0.5" value="8" class="flex-1 border-none bg-transparent outline-none px-3 py-2 text-body-md text-primary [appearance:textfield]" />
              <select data-unit="length" class="border-none bg-transparent outline-none text-accent-mustard text-body-sm cursor-pointer px-2 py-2">
                <option value="ft">ft</option>
                <option value="m">m</option>
              </select>
            </div>
          </div>
          <div>
            <label class="mb-1.5 block text-body-sm text-secondary">Quantity</label>
            <input data-input="quantity" type="number" step="1" min="1" value="1" class="w-full rounded-lg border border-subtle bg-primary px-3 py-2 text-body-md text-primary outline-none transition-colors focus:border-accent-mustard focus:ring-1 focus:ring-accent-mustard/40 [appearance:textfield]" />
          </div>
        </div>

        <div class="mt-6 grid grid-cols-2 gap-x-4 sm:grid-cols-4">
          <div class="sm:col-span-2">
            <label class="mb-1.5 block text-body-sm text-secondary">
              Price / BF
              <span class="text-muted" data-unit-label="price">$/BF</span>
            </label>
            <div class="flex gap-2">
              <select data-currency class="shrink-0 rounded-lg border border-subtle bg-primary px-2.5 py-2 text-body-sm text-primary outline-none transition-colors focus:border-accent-mustard focus:ring-1 focus:ring-accent-mustard/40 cursor-pointer">
                <option value="USD">$ USD</option>
                <option value="EUR">€ EUR</option>
                <option value="GBP">£ GBP</option>
                <option value="CAD">C$ CAD</option>
                <option value="AUD">A$ AUD</option>
                <option value="JPY">¥ JPY</option>
                <option value="CNY">¥ CNY</option>
                <option value="INR">₹ INR</option>
                <option value="BRL">R$ BRL</option>
                <option value="MXN">$ MXN</option>
              </select>
              <div class="relative flex-1">
                <input
                  data-input="price"
                  type="number"
                  step="0.01"
                  min="0"
                  value="0"
                  class="w-full rounded-lg border border-subtle bg-primary px-3 py-2 text-body-md text-primary outline-none transition-colors focus:border-accent-mustard focus:ring-1 focus:ring-accent-mustard/40"
                />

              </div>
            </div>
          </div>
          <div class="flex items-end sm:col-span-2 sm:justify-end">
            <button
              data-action="add-to-cart"
              class="w-full rounded-lg bg-accent-mustard px-4 py-2.5 text-body-md-strong text-white transition-opacity hover:opacity-90 cursor-pointer"
            >
              Add to Cut List
            </button>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-3 gap-4 rounded-lg bg-secondary p-4">
          <div class="text-center">
            <span class="text-caption text-secondary">Per Board</span>
            <p class="mt-0.5 text-display-sm text-primary" data-result-bf>0 BF</p>
          </div>
          <div class="text-center">
            <span class="text-caption text-secondary">Total BF</span>
            <p class="mt-0.5 text-display-sm text-primary" data-result-total-bf>0 BF</p>
          </div>
          <div class="text-center">
            <span class="text-caption text-secondary">Total Cost</span>
            <p class="mt-0.5 text-display-sm text-primary" data-result-cost>$0.00</p>
          </div>
        </div>
        <p class="mt-1.5 text-center text-caption text-muted">
          Cost = Total BF &times; Price / BF &nbsp;&middot;&nbsp; Waste factor applied to cut list totals
        </p>
      </Card>
    </div>

    <!-- Lumber Preview — Column 2 -->
    <div>
      <Card class="h-full flex flex-col">
        <h3 class="mb-4 text-display-sm text-primary">Lumber Preview</h3>
        <div class="flex flex-1 items-center justify-center p-2" data-visualizer-root>
          <svg class="w-full max-w-sm h-auto" viewBox="0 0 260 200" fill="none" xmlns="http://www.w3.org/2000/svg" data-visualizer-svg>
            <!-- Side face (back) -->
            <polygon data-viz="side" fill="var(--bg-primary)" stroke="var(--border-subtle)" stroke-width="1.2" stroke-linejoin="round" />
            <!-- Top face -->
            <polygon data-viz="top" fill="var(--bg-secondary)" stroke="var(--border-subtle)" stroke-width="1.2" stroke-linejoin="round" />
            <!-- Front face (front) -->
            <polygon data-viz="front" fill="var(--bg-primary)" stroke="var(--border-subtle)" stroke-width="1.2" stroke-linejoin="round" />

            <!-- Dimension labels -->
            <text data-viz="label-w" font-size="11" fill="var(--text-secondary)" text-anchor="middle" font-family="var(--font-mono)" font-weight="500" />
            <text data-viz="label-l" font-size="11" fill="var(--text-secondary)" text-anchor="end" font-family="var(--font-mono)" font-weight="500" />
            <text data-viz="label-t" font-size="11" fill="var(--text-secondary)" text-anchor="middle" font-family="var(--font-mono)" font-weight="500" />

            <!-- Dimension indicator icons -->
            <line data-viz="dimline-w" stroke="var(--accent-mustard)" stroke-width="1.5" stroke-linecap="round" />
            <line data-viz="dimline-l" stroke="var(--accent-mustard)" stroke-width="1.5" stroke-linecap="round" />
            <line data-viz="dimline-t" stroke="var(--accent-mustard)" stroke-width="1.5" stroke-linecap="round" />
            <circle data-viz="dot-w1" r="2.5" fill="var(--accent-mustard)" />
            <circle data-viz="dot-w2" r="2.5" fill="var(--accent-mustard)" />
            <circle data-viz="dot-l1" r="2.5" fill="var(--accent-mustard)" />
            <circle data-viz="dot-l2" r="2.5" fill="var(--accent-mustard)" />
            <circle data-viz="dot-t1" r="2.5" fill="var(--accent-mustard)" />
            <circle data-viz="dot-t2" r="2.5" fill="var(--accent-mustard)" />
          </svg>
        </div>
        <p class="mt-1 text-center text-caption text-muted">
          Board dimensions — not to scale
        </p>
      </Card>
    </div>

    <!-- Project Cut List — Full width below -->
    <div class="cut-list-section" data-cutlist-root>
      <Card class="flex flex-col">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
          <h3 class="text-display-sm text-primary">Project Cut List</h3>
          <div class="flex flex-wrap items-center gap-3 sm:gap-4">
            <span class="text-body-sm text-secondary" data-total-summary-bf>Total: 0 BF</span>
            <span class="text-body-sm text-secondary" data-total-summary-cost>Cost: $0.00</span>
            <button
              data-action="clear-all"
              class="linear-card px-3 py-1.5 text-body-sm text-secondary transition-colors hover:bg-secondary cursor-pointer"
            >
              Clear All
            </button>
          </div>
        </div>

        <div>
          <div
            class="flex flex-col items-center justify-center linear-card px-6 py-12 text-center"
            data-empty-state
          >
            <svg class="mb-3 h-8 w-8 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
            <p class="text-body-md text-muted">No items yet.</p>
            <p class="mt-1 text-body-sm text-muted">Add boards above to build your cut list.</p>
          </div>

          <div class="hidden overflow-x-auto linear-card" data-table-wrapper>
            <table class="w-full text-left text-body-sm">
              <thead>
                <tr class="border-b border-subtle bg-secondary">
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">Thickness</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">Width</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">Length</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">Qty</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">BF</th>
                  <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted">Cost</th>
                  <th class="px-4 py-3"></th>
                </tr>
              </thead>
              <tbody data-table-body></tbody>
            </table>
          </div>
        </div>
      </Card>
    </div>
  </div>

  <!-- Waste Factor -->
  <div class="mx-auto mt-6 max-w-xl">
    <Card>
      <div class="flex items-center justify-between">
        <label class="text-body-sm-strong text-secondary" for="waste-slider">
          Waste Factor
        </label>
        <span class="font-mono text-body-md text-primary" data-waste-value>5%</span>
      </div>
      <input
        id="waste-slider"
        data-input="waste"
        type="range"
        min="0"
        max="50"
        value="5"
        step="1"
        class="mt-2 block w-full cursor-pointer accent-accent-mustard"
      />
      <div class="mt-1 flex justify-between text-caption text-muted">
        <span>0%</span>
        <span>50%</span>
      </div>
    </Card>
  </div>
</section>

<style>
  [data-visualizer-svg] text {
    user-select: none;
    pointer-events: none;
  }
</style>

<script>
  (() => {
    const STORAGE_KEY = "bfc_cutlist";

    const CURRENCIES = { USD:"$", EUR:"€", GBP:"£", CAD:"C$", AUD:"A$", JPY:"¥", CNY:"¥", INR:"₹", BRL:"R$", MXN:"$" };
    const state = { units: { thickness: "in", width: "in", length: "ft" }, waste: 5, cutList: [], currency: "USD" };

    const $ = (s) => document.querySelector(s);
    const $$ = (s) => document.querySelectorAll(s);

    const root = $("[data-calculator-root]");
    if (!root) return;

    const inputs = {
      thickness: $("[data-input='thickness']"),
      width: $("[data-input='width']"),
      length: $("[data-input='length']"),
      quantity: $("[data-input='quantity']"),
      price: $("[data-input='price']"),
      waste: $("[data-input='waste']"),
      unitT: $("[data-unit='thickness']"),
      unitW: $("[data-unit='width']"),
      unitL: $("[data-unit='length']"),
    };

    const ui = {
      price: $("[data-unit-label='price']"),
      bf: $("[data-result-bf]"),
      totalBf: $("[data-result-total-bf]"),
      cost: $("[data-result-cost]"),
      waste: $("[data-waste-value]"),
      presets: $("[data-presets-list]"),
      add: $("[data-action='add-to-cart']"),
      clear: $("[data-action='clear-all']"),
      empty: $("[data-empty-state]"),
      table: $("[data-table-wrapper]"),
      body: $("[data-table-body]"),
      summaryBf: $("[data-total-summary-bf]"),
      summaryCost: $("[data-total-summary-cost]"),
      currency: $("[data-currency]"),
    };

    let vis = {};

    function toIn(v, u) { return u === "mm" ? v/25.4 : v; }
    function toFt(v, u) { return u === "m" ? v/0.3048 : v; }
    function bf(t, w, l) {
      return toIn(t,state.units.thickness) * toIn(w,state.units.width) * toFt(l,state.units.length) / 12;
    }
    const sym = () => CURRENCIES[state.currency] || "$";
    const fmt = (v) => sym()+v.toFixed(2);
    const fmtBf = (v) => v.toFixed(2)+" BF";

    function labels() {
      if (ui.price) ui.price.textContent = sym()+"/BF";
    }

    function live() {
      const t = +inputs.thickness.value||0, w = +inputs.width.value||0, l = +inputs.length.value||0;
      const q = +inputs.quantity.value||1, p = +inputs.price.value||0;
      const per = bf(t,w,l);
      const totalBf = per * q;
      ui.bf.textContent = fmtBf(per);
      ui.totalBf.textContent = fmtBf(totalBf);
      ui.cost.textContent = fmt(totalBf * p);
    }

    function initVis() {
      vis = {
        front: document.querySelector("[data-viz='front']"),
        top: document.querySelector("[data-viz='top']"),
        side: document.querySelector("[data-viz='side']"),
        labelW: document.querySelector("[data-viz='label-w']"),
        labelL: document.querySelector("[data-viz='label-l']"),
        labelT: document.querySelector("[data-viz='label-t']"),
        dimlineW: document.querySelector("[data-viz='dimline-w']"),
        dimlineL: document.querySelector("[data-viz='dimline-l']"),
        dimlineT: document.querySelector("[data-viz='dimline-t']"),
        dotW1: document.querySelector("[data-viz='dot-w1']"),
        dotW2: document.querySelector("[data-viz='dot-w2']"),
        dotL1: document.querySelector("[data-viz='dot-l1']"),
        dotL2: document.querySelector("[data-viz='dot-l2']"),
        dotT1: document.querySelector("[data-viz='dot-t1']"),
        dotT2: document.querySelector("[data-viz='dot-t2']"),
      };
    }

    function viz() {
      if (!vis.front) initVis();
      let t = +inputs.thickness.value||1, w = +inputs.width.value||1, l = +inputs.length.value||1;
      t = toIn(t,state.units.thickness); w = toIn(w,state.units.width); l = toFt(l,state.units.length);
      const max = Math.max(t,w,l);
      if (max===0) return;

      const scale = 54 / max;
      const sw = Math.max(28, Math.min(92, w * scale));
      const sl = Math.max(22, Math.min(72, l * scale));
      const st = Math.max(10, Math.min(38, t * scale));
      const ox = st * 0.48;
      const oy = st * 0.28;

      const cx = 130, cy = 102;

      function pt(x, y) { return x.toFixed(1)+","+y.toFixed(1); }

      const p0 = [cx - sw/2, cy + sl/2];
      const p1 = [cx + sw/2, cy + sl/2];
      const p2 = [cx + sw/2, cy - sl/2];
      const p3 = [cx - sw/2, cy - sl/2];
      const p4 = [cx + sw/2 + ox, cy + sl/2 - oy];
      const p5 = [cx + sw/2 + ox, cy - sl/2 - oy];
      const p6 = [cx - sw/2 + ox, cy - sl/2 - oy];

      if (vis.side) vis.side.setAttribute("points",
        pt(p1[0],p1[1])+" "+pt(p4[0],p4[1])+" "+pt(p5[0],p5[1])+" "+pt(p2[0],p2[1]));
      if (vis.top) vis.top.setAttribute("points",
        pt(p3[0],p3[1])+" "+pt(p2[0],p2[1])+" "+pt(p5[0],p5[1])+" "+pt(p6[0],p6[1]));
      if (vis.front) vis.front.setAttribute("points",
        pt(p0[0],p0[1])+" "+pt(p1[0],p1[1])+" "+pt(p2[0],p2[1])+" "+pt(p3[0],p3[1]));

      const wu = state.units.width, lu = state.units.length, tu = state.units.thickness;

      if (vis.labelW) {
        vis.labelW.setAttribute("x", cx);
        vis.labelW.setAttribute("y", cy + sl/2 + 14);
        vis.labelW.textContent = "W: "+w.toFixed(2)+" "+wu;
      }
      if (vis.labelL) {
        vis.labelL.setAttribute("x", cx - sw/2 - 10);
        vis.labelL.setAttribute("y", cy + 4);
        vis.labelL.textContent = "L: "+l.toFixed(2)+" "+lu;
      }
      if (vis.labelT) {
        vis.labelT.setAttribute("x", cx + sw/2 + ox/2);
        vis.labelT.setAttribute("y", cy - sl/2 - oy - 6);
        vis.labelT.textContent = "T: "+t.toFixed(2)+" "+tu;
      }

      if (vis.dimlineW) {
        vis.dimlineW.setAttribute("x1", p0[0]); vis.dimlineW.setAttribute("y1", p0[1]+6);
        vis.dimlineW.setAttribute("x2", p1[0]); vis.dimlineW.setAttribute("y2", p1[1]+6);
      }
      if (vis.dimlineL) {
        vis.dimlineL.setAttribute("x1", p3[0]-6); vis.dimlineL.setAttribute("y1", p3[1]);
        vis.dimlineL.setAttribute("x2", p0[0]-6); vis.dimlineL.setAttribute("y2", p0[1]);
      }
      if (vis.dimlineT) {
        vis.dimlineT.setAttribute("x1", p2[0]); vis.dimlineT.setAttribute("y1", p2[1]-4);
        vis.dimlineT.setAttribute("x2", p5[0]); vis.dimlineT.setAttribute("y2", p5[1]-4);
      }

      if (vis.dotW1) { vis.dotW1.setAttribute("cx", p0[0]); vis.dotW1.setAttribute("cy", p0[1]+6); }
      if (vis.dotW2) { vis.dotW2.setAttribute("cx", p1[0]); vis.dotW2.setAttribute("cy", p1[1]+6); }
      if (vis.dotL1) { vis.dotL1.setAttribute("cx", p3[0]-6); vis.dotL1.setAttribute("cy", p3[1]); }
      if (vis.dotL2) { vis.dotL2.setAttribute("cx", p0[0]-6); vis.dotL2.setAttribute("cy", p0[1]); }
      if (vis.dotT1) { vis.dotT1.setAttribute("cx", p2[0]); vis.dotT1.setAttribute("cy", p2[1]-4); }
      if (vis.dotT2) { vis.dotT2.setAttribute("cx", p5[0]); vis.dotT2.setAttribute("cy", p5[1]-4); }
    }

    function save() { try { localStorage.setItem(STORAGE_KEY,JSON.stringify(state.cutList)); localStorage.setItem("bfc_currency",state.currency); } catch(e) {} }
    function load() { try { const d=localStorage.getItem(STORAGE_KEY); if(d) state.cutList=JSON.parse(d); const c=localStorage.getItem("bfc_currency"); if(c&&CURRENCIES[c]) state.currency=c; } catch(e) {} }

    function render() {
      const items = state.cutList;
      if (!items.length) {
        ui.empty.classList.remove("hidden"); ui.table.classList.add("hidden");
        tot(); return;
      }
      ui.empty.classList.add("hidden"); ui.table.classList.remove("hidden");
      const ul = state.unit==="imperial"?"in":"mm", ll = state.unit==="imperial"?"ft":"m";
      ui.body.innerHTML = items.map((it,i) =>
        `<tr class="border-b border-subtle transition-colors hover:bg-secondary">
          <td class="px-4 py-3 text-body-sm text-primary">${it.t.toFixed(2)} ${ul}</td>
          <td class="px-4 py-3 text-body-sm text-primary">${it.w.toFixed(2)} ${ul}</td>
          <td class="px-4 py-3 text-body-sm text-primary">${it.l.toFixed(2)} ${ll}</td>
          <td class="px-4 py-3 text-body-sm text-primary">${it.q}</td>
          <td class="px-4 py-3 font-mono text-body-sm text-primary">${it.bf.toFixed(2)} BF</td>
          <td class="px-4 py-3 font-mono text-body-sm text-primary">${fmt(it.c)}</td>
          <td class="px-4 py-3 text-right">
            <button data-remove="${i}" class="linear-card px-2 py-1 text-body-sm text-muted transition-colors hover:bg-secondary cursor-pointer">Remove</button>
          </td>
        </tr>`
      ).join("");
      ui.body.querySelectorAll("[data-remove]").forEach(b=>b.addEventListener("click",()=>{
        state.cutList.splice(+b.dataset.remove,1); save(); render(); tot();
      }));
      tot();
    }

    function tot() {
      const items = state.cutList;
      if (!items.length) { ui.summaryBf.textContent="Total: 0 BF"; ui.summaryCost.textContent="Cost: $0.00"; return; }
      let bs=0, cs=0;
      for (const it of items) { bs+=it.bf; cs+=it.c; }
      const m = 1+state.waste/100;
      ui.summaryBf.textContent = `Total: ${(bs*m).toFixed(2)} BF (incl. ${state.waste}% waste)`;
      ui.summaryCost.textContent = `Cost: ${fmt(cs*m)}`;
    }

    function add() {
      const t=+inputs.thickness.value||0, w=+inputs.width.value||0, l=+inputs.length.value||0;
      const q=+inputs.quantity.value||1, p=+inputs.price.value||0;
      if (t<=0||w<=0||l<=0) return;
      const per = bf(t,w,l);
      state.cutList.push({t,w,l,q,bf:per*q,c:per*q*p});
      save(); render(); tot();
    }

    function clearAll() { if (!state.cutList.length) return; state.cutList=[]; save(); render(); }

    function preset(v) {
      const p=v.split(","); if (p.length<3) return;
      inputs.thickness.value=p[0]; inputs.width.value=p[1]; inputs.length.value=p[2];
      live(); viz();
    }

    function init() {
      load();
      initVis();
      const unitKeys = [["thickness","unitT"],["width","unitW"],["length","unitL"]];
      unitKeys.forEach(([k,uk])=>{
        const sel = inputs[uk];
        if(!sel) return;
        sel.value=state.units[k];
        sel.addEventListener("change",()=>{ state.units[k]=sel.value; labels(); live(); viz(); });
      });
      Object.values(inputs).forEach(el=>{ if(!el) return; el.addEventListener("input",()=>{
        if(el===inputs.waste){ state.waste=+el.value||5; ui.waste.textContent=state.waste+"%"; tot(); return; }
        live(); viz();
      })});
      if (ui.presets) ui.presets.addEventListener("click",e=>{ const b=e.target.closest("[data-preset]"); if(b) preset(b.dataset.preset); });
      ui.add.addEventListener("click",add);
      Object.values(inputs).forEach(el=>{ if(!el||el===inputs.waste) return; el.addEventListener("keydown",e=>{ if(e.key==="Enter") add(); }); });
      ui.clear.addEventListener("click",clearAll);
      if (ui.currency) {
        ui.currency.value=state.currency;
        ui.currency.addEventListener("change",()=>{ state.currency=ui.currency.value; save(); labels(); live(); render(); });
      }
      labels(); live(); viz(); render();
      if (ui.waste) ui.waste.textContent=state.waste+"%";
    }

    if (document.readyState==="loading") document.addEventListener("DOMContentLoaded",init); else init();
  })();
</script>
