---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="500 — Server Error"
  description="Something went wrong on our end. Please try again later."
>
  <NavBar />

  <main class="bg-primary">
    <div class="mx-auto flex min-h-[60vh] max-w-2xl flex-col items-center justify-center px-8 sm:px-14 lg:px-24 text-center">
      <span class="font-mono text-[120px] leading-none text-accent-mustard font-semibold tracking-tight">500</span>
      <h1 class="mt-4 text-display-lg text-primary">Something went wrong.</h1>
      <p class="mt-3 text-body-md text-secondary">
        An unexpected error occurred. Please try again, or contact us if the problem persists.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center rounded-lg bg-accent-mustard px-6 py-2.5 text-body-md-strong text-white no-underline transition-opacity hover:opacity-90"
      >
        Back to Calculator
      </a>
    </div>
  </main>

  <Footer />
</Layout>
