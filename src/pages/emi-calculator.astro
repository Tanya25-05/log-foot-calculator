---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="EMI Calculator — Loan EMI Calculator with Visual Breakdown"
  description="EMI calculator for home loans, car loans, and personal loans. Calculate monthly EMI, total interest payable, and see a dynamic principal vs interest breakdown."
>
  <NavBar />

  <main class="bg-primary">
    <section class="mx-auto max-w-7xl px-8 py-12 sm:px-14 lg:px-24 lg:py-16" data-emi-root>
      <div class="mb-10 text-center">
        <span class="inline-block rounded-full bg-secondary px-3 py-1 text-caption-mono font-mono uppercase tracking-wide text-muted" data-i18n="emi.badge">Online Tool</span>
        <h2 class="mt-4 text-display-xl text-primary text-balance" data-i18n="emi.heading">EMI Calculator.</h2>
        <p class="mx-auto mt-3 max-w-2xl text-body-lg text-secondary" data-i18n="emi.subtitle">Plan your loan with real-time EMI calculations and a visual breakdown of principal vs interest.</p>
      </div>

      <div class="calculator-layout">
        <!-- Inputs Column -->
        <div>
          <div class="linear-card p-6 lg:p-8">
            <h3 class="mb-6 text-display-sm text-primary" data-i18n="emi.loan_details">Loan Details</h3>
            <div class="flex flex-col gap-6">
              <!-- Loan Amount -->
              <div>
                <div class="mb-2 flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2">
                    <label class="text-body-sm text-secondary" data-i18n="emi.loan_amount">Loan Amount</label>
                    <select data-emi-currency class="rounded-lg border border-subtle bg-primary px-1.5 py-0.5 text-body-sm text-primary outline-none transition-colors focus:border-accent-mustard focus:ring-1 focus:ring-accent-mustard/40 cursor-pointer">
                      <option value="INR">₹ INR</option>
                      <option value="USD">$ USD</option>
                      <option value="EUR">€ EUR</option>
                      <option value="GBP">£ GBP</option>
                      <option value="CAD">C$ CAD</option>
                      <option value="AUD">A$ AUD</option>
                      <option value="JPY">¥ JPY</option>
                      <option value="CNY">¥ CNY</option>
                      <option value="BRL">R$ BRL</option>
                    </select>
                  </div>
                  <input type="number" data-emi-input-num="amount" value="500000" class="w-32 rounded-lg border border-subtle bg-primary px-2.5 py-1 text-body-md text-primary outline-none transition-colors text-right font-mono focus:border-accent-mustard focus:ring-1 focus:ring-accent-mustard/40 [appearance:textfield]" />
                </div>
                <input type="range" data-emi-input="amount" min="10000" max="10000000" step="10000" value="500000" class="mt-1 block w-full cursor-pointer accent-accent-mustard" />
                <div class="mt-1 flex justify-between text-caption text-muted">
                  <span data-currency-prefix>₹</span>10K <span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> <span data-currency-prefix>₹</span>1Cr
                </div>
              </div>

              <!-- Interest Rate -->
              <div>
                <div class="mb-2 flex items-center justify-between">
                  <label class="text-body-sm text-secondary" data-i18n="emi.interest_rate">Interest Rate</label>
                  <div class="flex items-center gap-2">
                    <input type="number" data-emi-input-num="rate" value="8.5" step="0.1" min="0.5" max="30" class="w-20 rounded-lg border border-subtle bg-primary px-2.5 py-1 text-body-md text-primary outline-none transition-colors text-right font-mono focus:border-accent-mustard focus:ring-1 focus:ring-accent-mustard/40 [appearance:textfield]" />
                    <span class="text-body-sm text-muted font-mono">%</span>
                  </div>
                </div>
                <input type="range" data-emi-input="rate" min="0.5" max="30" step="0.1" value="8.5" class="mt-1 block w-full cursor-pointer accent-accent-mustard" />
                <div class="mt-1 flex justify-between text-caption text-muted">
                  <span>0.5%</span>
                  <span>30%</span>
                </div>
              </div>

              <!-- Loan Tenure -->
              <div>
                <div class="mb-2 flex items-center justify-between">
                  <label class="text-body-sm text-secondary" data-i18n="emi.tenure">Loan Tenure</label>
                  <div class="flex items-center gap-2">
                    <input type="number" data-emi-input-num="tenure" value="20" step="1" min="1" max="40" class="w-16 rounded-lg border border-subtle bg-primary px-2.5 py-1 text-body-md text-primary outline-none transition-colors text-right font-mono focus:border-accent-mustard focus:ring-1 focus:ring-accent-mustard/40 [appearance:textfield]" />
                    <span class="text-body-sm text-muted font-mono">Years</span>
                  </div>
                </div>
                <input type="range" data-emi-input="tenure" min="1" max="40" step="1" value="20" class="mt-1 block w-full cursor-pointer accent-accent-mustard" />
                <div class="mt-1 flex justify-between text-caption text-muted">
                  <span>1 Year</span>
                  <span>40 Years</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Results + Visuals Column -->
        <div class="flex flex-col gap-6">
          <!-- EMI Result -->
          <div class="linear-card p-6 lg:p-8">
            <div class="mb-6">
              <span class="text-caption text-secondary" data-i18n="emi.monthly_emi">Monthly EMI</span>
              <p class="mt-1 text-display-xl text-primary font-mono" data-emi-result="emi">₹5,234</p>
            </div>

            <div class="grid grid-cols-2 gap-6">
              <div class="rounded-lg bg-secondary p-4">
                <span class="text-caption text-secondary" data-i18n="emi.total_interest">Total Interest</span>
                <p class="mt-1 text-display-sm text-[#EF4444] font-mono" data-emi-result="interest">₹7,56,234</p>
              </div>
              <div class="rounded-lg bg-secondary p-4">
                <span class="text-caption text-secondary" data-i18n="emi.total_payment">Total Payment</span>
                <p class="mt-1 text-display-sm text-primary font-mono" data-emi-result="total">₹12,56,234</p>
              </div>
            </div>
          </div>

          <!-- Debt vs Profit Visual Bar -->
          <div class="linear-card p-6 lg:p-8">
            <h3 class="mb-4 text-display-sm text-primary" data-i18n="emi.breakdown">Principal vs Interest Breakdown</h3>

            <!-- Stacked Bar -->
            <div class="relative h-12 w-full overflow-hidden rounded-lg bg-secondary" data-vis-bar>
              <div class="absolute left-0 top-0 h-full transition-all duration-300 ease-out" data-vis-bar-principal style="background: #10B981; width: 40%;"></div>
              <div class="absolute top-0 h-full transition-all duration-300 ease-out" data-vis-bar-interest style="background: #EF4444; left: 40%; width: 60%;"></div>
            </div>

            <!-- Legend -->
            <div class="mt-4 flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="inline-block h-3 w-3 rounded-sm bg-[#10B981]"></span>
                <span class="text-body-sm text-secondary" data-i18n="emi.principal">Principal (Your Debt)</span>
                <span class="font-mono text-body-sm text-primary" data-emi-legend="principal">40%</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="inline-block h-3 w-3 rounded-sm bg-[#EF4444]"></span>
                <span class="text-body-sm text-secondary" data-i18n="emi.interest">Interest (Bank's Profit)</span>
                <span class="font-mono text-body-sm text-primary" data-emi-legend="interest">60%</span>
              </div>
            </div>

            <!-- Donut Chart -->
            <div class="mt-6 flex justify-center">
              <div class="relative h-40 w-40">
                <div class="h-full w-full rounded-full" data-donut style="background: conic-gradient(#10B981 0% 40%, #EF4444 40% 100%)"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="h-20 w-20 rounded-full bg-primary"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Amortization Schedule -->
        <div class="cut-list-section">
          <div class="linear-card p-6 lg:p-8">
            <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
              <h3 class="text-display-sm text-primary" data-i18n="emi.amortization">Amortization Schedule</h3>
              <div class="flex items-center gap-3">
                <span class="text-body-sm text-secondary" data-emi-summary>Year 1 of 20</span>
                <button data-emi-amort-toggle class="linear-card px-3 py-1.5 text-body-sm text-secondary transition-colors hover:bg-secondary cursor-pointer" data-i18n="emi.show_table">Show Table</button>
              </div>
            </div>

            <div class="hidden overflow-x-auto linear-card" data-amort-wrapper>
              <table class="w-full text-left text-body-sm">
                <thead>
                  <tr class="border-b border-subtle bg-secondary">
                    <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted" data-i18n="emi.year">Year</th>
                    <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted" data-i18n="emi.emi_paid">EMI Paid</th>
                    <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted" data-i18n="emi.principal_paid">Principal Paid</th>
                    <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted" data-i18n="emi.interest_paid">Interest Paid</th>
                    <th class="px-4 py-3 font-mono text-caption uppercase tracking-wide text-muted" data-i18n="emi.balance">Balance</th>
                  </tr>
                </thead>
                <tbody data-amort-body></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- How It Works Section -->
      <section class="mt-16 border-t border-subtle pt-16">
        <div class="mx-auto">
          <div class="mx-auto max-w-2xl text-center">
            <span class="inline-block rounded-full bg-secondary px-3 py-1 text-caption-mono font-mono uppercase tracking-wide text-muted border border-subtle" data-i18n="how.guide">Guide</span>
            <h2 class="mt-4 text-display-lg text-primary" data-i18n="emi.how_title">How EMI works.</h2>
            <p class="mt-3 text-body-md text-secondary" data-i18n="emi.how_desc">EMI stands for Equated Monthly Installment — a fixed payment you make each month to repay a loan over a set period.</p>
          </div>

          <div class="relative mt-12 grid gap-6 sm:grid-cols-3">
            <div class="relative flex flex-col items-center text-center">
              <div class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full bg-accent-mustard text-white shadow-card">
                <span class="text-body-md-strong font-mono">1</span>
              </div>
              <div class="mt-2 hidden sm:block absolute top-6 left-[calc(50%+2.5rem)] right-[calc(-50%+2.5rem)] h-px bg-[var(--border-subtle)] -z-0"></div>
              <div class="mt-6 w-full linear-card p-6">
                <h3 class="text-display-sm text-primary" data-i18n="emi.step1_title">Enter loan details</h3>
                <p class="mt-2 text-body-sm text-secondary" data-i18n="emi.step1_desc">Set the loan amount, interest rate, and tenure using the sliders. Results update instantly.</p>
              </div>
            </div>
            <div class="relative flex flex-col items-center text-center">
              <div class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full bg-accent-mustard text-white shadow-card">
                <span class="text-body-md-strong font-mono">2</span>
              </div>
              <div class="mt-2 hidden sm:block absolute top-6 left-[calc(50%+2.5rem)] right-[calc(-50%+2.5rem)] h-px bg-[var(--border-subtle)] -z-0"></div>
              <div class="mt-6 w-full linear-card p-6">
                <h3 class="text-display-sm text-primary" data-i18n="emi.step2_title">See the breakdown</h3>
                <p class="mt-2 text-body-sm text-secondary" data-i18n="emi.step2_desc">Watch the debt vs profit bar shift as you adjust parameters — a visual split of principal vs interest.</p>
              </div>
            </div>
            <div class="relative flex flex-col items-center text-center">
              <div class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full bg-accent-mustard text-white shadow-card">
                <span class="text-body-md-strong font-mono">3</span>
              </div>
              <div class="mt-6 w-full linear-card p-6">
                <h3 class="text-display-sm text-primary" data-i18n="emi.step3_title">Review amortization</h3>
                <p class="mt-2 text-body-sm text-secondary" data-i18n="emi.step3_desc">Open the year-by-year table to see how your balance declines and how much goes toward interest each year.</p>
              </div>
            </div>
          </div>

          <!-- Formula Callout -->
          <div class="mx-auto mt-12 max-w-xl rounded-lg formula-callout p-6 shadow-card">
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-accent-mustard shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
              </svg>
              <h3 class="text-display-sm text-primary" data-i18n="emi.formula_title">EMI Formula</h3>
            </div>
            <div class="mt-3 rounded-lg bg-primary p-4 font-mono text-body-sm text-primary border border-subtle leading-relaxed">
              <span class="text-muted">EMI</span> = <span class="text-[10px]">P &times; R &times; (1+R)<sup>N</sup> &divide; ((1+R)<sup>N</sup> &minus; 1)</span>
            </div>
            <div class="mt-3 space-y-1 text-caption text-muted leading-relaxed">
              <p><strong class="text-primary">P</strong> = Principal loan amount</p>
              <p><strong class="text-primary">R</strong> = Monthly interest rate (Annual Interest Rate &divide; 12 &divide; 100)</p>
              <p><strong class="text-primary">N</strong> = Loan tenure in months</p>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ Section -->
      <section class="mt-16 border-t border-subtle py-16">
        <div class="mx-auto max-w-3xl">
          <h2 class="text-center text-display-lg text-primary" data-i18n="emi.faq_heading">Frequently asked questions about EMI.</h2>
          <div class="mt-10 space-y-4" data-faq>
            <details class="linear-card p-4 open:ring-1 open:ring-accent-mustard/30">
              <summary class="cursor-pointer text-body-md-strong text-primary list-none flex items-center justify-between">
                <span data-i18n="emi.faq1_q">What is an EMI calculator?</span>
                <svg class="h-4 w-4 text-muted shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="mt-3 text-body-sm text-secondary leading-relaxed" data-i18n="emi.faq1_a">An EMI calculator estimates your monthly installment for any loan — home, car, personal, or education. Enter the loan amount, interest rate, and tenure, and it instantly shows your EMI, total interest payable, and total payment with a visual breakdown.</p>
            </details>
            <details class="linear-card p-4 open:ring-1 open:ring-accent-mustard/30">
              <summary class="cursor-pointer text-body-md-strong text-primary list-none flex items-center justify-between">
                <span data-i18n="emi.faq2_q">How is EMI calculated?</span>
                <svg class="h-4 w-4 text-muted shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="mt-3 text-body-sm text-secondary leading-relaxed" data-i18n="emi.faq2_a">EMI uses the formula: EMI = P × r × (1+r)^n / ((1+r)^n - 1), where P is the loan amount, r is the monthly interest rate (annual rate divided by 12), and n is the total number of monthly installments. This formula ensures each payment is the same amount every month while the principal decreases over time.</p>
            </details>
            <details class="linear-card p-4 open:ring-1 open:ring-accent-mustard/30">
              <summary class="cursor-pointer text-body-md-strong text-primary list-none flex items-center justify-between">
                <span data-i18n="emi.faq3_q">What does the debt vs profit bar show?</span>
                <svg class="h-4 w-4 text-muted shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="mt-3 text-body-sm text-secondary leading-relaxed" data-i18n="emi.faq3_a">The bar splits your total payment into two parts: the green section is the principal (your debt — what you borrowed), and the red section is the interest (the bank's profit). A longer red bar means more of your money goes toward interest. Adjust the loan parameters to see how shorter tenures and lower rates reduce the red portion.</p>
            </details>
            <details class="linear-card p-4 open:ring-1 open:ring-accent-mustard/30">
              <summary class="cursor-pointer text-body-md-strong text-primary list-none flex items-center justify-between">
                <span data-i18n="emi.faq4_q">How can I reduce my total interest?</span>
                <svg class="h-4 w-4 text-muted shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="mt-3 text-body-sm text-secondary leading-relaxed" data-i18n="emi.faq4_a">Two main ways: choose a shorter tenure (you pay more each month but far less interest overall) or negotiate a lower interest rate. Even a 0.5% rate difference can save you lakhs over 20 years. Use this calculator to compare scenarios side by side.</p>
            </details>
            <details class="linear-card p-4 open:ring-1 open:ring-accent-mustard/30">
              <summary class="cursor-pointer text-body-md-strong text-primary list-none flex items-center justify-between">
                <span data-i18n="emi.faq5_q">What is an amortization schedule?</span>
                <svg class="h-4 w-4 text-muted shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="mt-3 text-body-sm text-secondary leading-relaxed" data-i18n="emi.faq5_a">An amortization schedule breaks down each payment over the loan term, showing how much goes toward principal vs interest and what the remaining balance is after each period. In early years, most of your payment goes toward interest; in later years, it shifts toward principal.</p>
            </details>
          </div>
        </div>
      </section>
    </section>
  </main>

  <Footer />
</Layout>

<script>
(() => {
  const CURRENCIES = { INR:"₹", USD:"$", EUR:"€", GBP:"£", CAD:"C$", AUD:"A$", JPY:"¥", CNY:"¥", BRL:"R$" };
  const state = { amount: 500000, rate: 8.5, tenure: 20, currency: "INR" };

  const $ = s => document.querySelector(s);
  const root = $("[data-emi-root]");
  if (!root) return;

  const inputs = {
    amount: $("[data-emi-input='amount']"),
    rate: $("[data-emi-input='rate']"),
    tenure: $("[data-emi-input='tenure']"),
    currency: $("[data-emi-currency]"),
    numAmount: $("[data-emi-input-num='amount']"),
    numRate: $("[data-emi-input-num='rate']"),
    numTenure: $("[data-emi-input-num='tenure']"),
  };

  const displays = {
    amount: $("[data-emi-display='amount']"),
    rate: $("[data-emi-display='rate']"),
    tenure: $("[data-emi-display='tenure']"),
    emi: $("[data-emi-result='emi']"),
    interest: $("[data-emi-result='interest']"),
    total: $("[data-emi-result='total']"),
    legendP: $("[data-emi-legend='principal']"),
    legendI: $("[data-emi-legend='interest']"),
  };

  const vis = {
    barPrincipal: $("[data-vis-bar-principal]"),
    barInterest: $("[data-vis-bar-interest]"),
    donut: $("[data-donut]"),
    amortBody: $("[data-amort-body]"),
    amortWrapper: $("[data-amort-wrapper]"),
    amortToggle: $("[data-emi-amort-toggle]"),
    amortSummary: $("[data-emi-summary]"),
  };

  const sym = () => CURRENCIES[state.currency] || "₹";

  function fmtCurrency(n) {
    const s = sym();
    if (state.currency === "INR") {
      const x = Math.round(n).toString();
      const last3 = x.slice(-3);
      const rest = x.slice(0, -3);
      if (rest === "") return s + last3;
      const groups = [];
      for (let i = rest.length - 1, c = 0; i >= 0; i--, c++) {
        groups.push(rest[i]);
      }
      return s + groups.reverse().join("") + "," + last3;
    }
    return s + Math.round(n).toLocaleString("en-US");
  }

  function calcEMI(P, annualRate, years) {
    const r = annualRate / 12 / 100;
    const n = years * 12;
    if (r === 0) return { emi: P / n, totalPayment: P, totalInterest: 0, monthlyRate: r, months: n };
    const emi = P * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
    const totalPayment = emi * n;
    const totalInterest = totalPayment - P;
    return { emi, totalPayment, totalInterest, monthlyRate: r, months: n };
  }

  function computeAmort(P, annualRate, years) {
    const { emi, monthlyRate, months } = calcEMI(P, annualRate, years);
    const rows = [];
    let balance = P;
    let yearlyEMI = 0, yearlyPrincipal = 0, yearlyInterest = 0;

    for (let m = 1; m <= months; m++) {
      const interest = balance * monthlyRate;
      const principal = emi - interest;
      balance -= principal;
      yearlyEMI += emi;
      yearlyPrincipal += principal;
      yearlyInterest += interest;

      if (m % 12 === 0 || m === months) {
        rows.push({
          year: Math.ceil(m / 12),
          emi: yearlyEMI,
          principal: yearlyPrincipal,
          interest: yearlyInterest,
          balance: Math.max(0, balance),
        });
        yearlyEMI = 0;
        yearlyPrincipal = 0;
        yearlyInterest = 0;
      }
    }
    return rows;
  }

  function computeAndRender() {
    const P = state.amount;
    const annualRate = state.rate;
    const years = state.tenure;
    const { emi, totalPayment, totalInterest } = calcEMI(P, annualRate, years);

    displays.emi.textContent = fmtCurrency(emi);
    displays.interest.textContent = fmtCurrency(totalInterest);
    displays.total.textContent = fmtCurrency(totalPayment);

    const pctP = P / totalPayment * 100;
    const pctI = totalInterest / totalPayment * 100;
    displays.legendP.textContent = pctP.toFixed(1) + "%";
    displays.legendI.textContent = pctI.toFixed(1) + "%";

    vis.barPrincipal.style.width = pctP + "%";
    vis.barInterest.style.left = pctP + "%";
    vis.barInterest.style.width = pctI + "%";

    if (vis.donut) vis.donut.style.background = `conic-gradient(#10B981 0% ${pctP.toFixed(1)}%, #EF4444 ${pctP.toFixed(1)}% 100%)`;
  }

  function renderAmort() {
    const rows = computeAmort(state.amount, state.rate, state.tenure);
    const totalYears = rows.length;

    vis.amortBody.innerHTML = rows.map(r => {
      const balFmt = fmtCurrency(r.balance);
      const emiFmt = fmtCurrency(r.emi);
      const prinFmt = fmtCurrency(r.principal);
      const intFmt = fmtCurrency(r.interest);
      return `<tr class="border-b border-subtle transition-colors hover:bg-secondary">
        <td class="px-4 py-3 text-body-sm text-primary font-mono">${r.year}</td>
        <td class="px-4 py-3 font-mono text-body-sm text-primary">${emiFmt}</td>
        <td class="px-4 py-3 font-mono text-body-sm text-primary">${prinFmt}</td>
        <td class="px-4 py-3 font-mono text-body-sm text-primary">${intFmt}</td>
        <td class="px-4 py-3 font-mono text-body-sm text-primary">${balFmt}</td>
      </tr>`;
    }).join("");

    vis.amortSummary.textContent = `Year 1 of ${totalYears}`;
  }

  function updateCurrencyPrefix() {
    const sym = CURRENCIES[state.currency] || "₹";
    document.querySelectorAll("[data-currency-prefix]").forEach(el => {
      el.textContent = sym;
    });
  }

  function live() {
    state.amount = +inputs.amount.value;
    state.rate = +inputs.rate.value;
    state.tenure = +inputs.tenure.value;
    state.currency = inputs.currency.value;

    inputs.numAmount.value = state.amount;
    inputs.numRate.value = state.rate;
    inputs.numTenure.value = state.tenure;

    try { localStorage.setItem("bfc_emi", JSON.stringify(state)); } catch (e) {}

    updateCurrencyPrefix();
    computeAndRender();
    renderAmort();
  }

  function init() {
    try {
      const d = localStorage.getItem("bfc_emi");
      if (d) {
        const saved = JSON.parse(d);
        if (saved && saved.amount != null) {
          state.amount = saved.amount;
          state.rate = saved.rate;
          state.tenure = saved.tenure;
          state.currency = saved.currency || "INR";
        }
      }
    } catch (e) {}

    inputs.amount.value = state.amount;
    inputs.rate.value = state.rate;
    inputs.tenure.value = state.tenure;
    inputs.currency.value = state.currency;

    inputs.amount.addEventListener("input", live);
    inputs.rate.addEventListener("input", live);
    inputs.tenure.addEventListener("input", live);
    inputs.currency.addEventListener("change", live);

    inputs.numAmount.addEventListener("input", () => {
      const v = +inputs.numAmount.value;
      if (v >= 10000 && v <= 10000000) { inputs.amount.value = v; live(); }
    });
    inputs.numRate.addEventListener("input", () => {
      const v = +inputs.numRate.value;
      if (v >= 0.5 && v <= 30) { inputs.rate.value = v; live(); }
    });
    inputs.numTenure.addEventListener("input", () => {
      const v = +inputs.numTenure.value;
      if (v >= 1 && v <= 40) { inputs.tenure.value = v; live(); }
    });

    vis.amortToggle.addEventListener("click", () => {
      const hidden = vis.amortWrapper.classList.contains("hidden");
      vis.amortWrapper.classList.toggle("hidden");
      vis.amortToggle.textContent = hidden
        ? (window.i18n?.t("emi.hide_table") || "Hide Table")
        : (window.i18n?.t("emi.show_table") || "Show Table");
      if (hidden) renderAmort();
    });

    document.addEventListener("i18nchange", () => {
      const showing = !vis.amortWrapper.classList.contains("hidden");
      vis.amortToggle.textContent = showing
        ? (window.i18n?.t("emi.hide_table") || "Hide Table")
        : (window.i18n?.t("emi.show_table") || "Show Table");
    });

    document.querySelectorAll("[data-faq] details").forEach(d => {
      d.querySelector("summary")?.addEventListener("click", e => {
        e.preventDefault();
        d.open = !d.open;
      });
    });

    live();
  }

  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init); else init();
})();
</script>
