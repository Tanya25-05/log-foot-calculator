---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import { SITE_CONFIG } from "../config";
const BUTTON_ID = SITE_CONFIG.razorpayPaymentButtonId;
---

<Layout
  title="Donate — Support Board Foot Calculator"
  description="Support Board Foot Calculator with a donation. Your contribution helps keep this tool free, ad-free, and constantly improving."
>
  <NavBar />

  <main class="bg-primary">
    <div class="mx-auto max-w-2xl px-8 py-16 sm:px-14 lg:px-24 lg:py-24">
      <span class="inline-block rounded-full bg-secondary px-3 py-1 text-caption-mono font-mono uppercase tracking-wide text-muted">
        Donate
      </span>
      <h1 class="mt-4 text-display-xl text-primary text-balance">Support a free tool for makers.</h1>
      <p class="mt-3 text-body-md text-secondary leading-relaxed max-w-lg">
        Board Foot Calculator will always be free, with no ads and no trackers. If this tool has helped you with a project, consider making a donation — every contribution helps keep it running.
      </p>

      <div class="mt-10 rounded-lg border border-subtle bg-secondary p-6">
        <p class="text-body-sm text-secondary mb-4">One-time donation via Razorpay</p>
        <form><script async src="https://checkout.razorpay.com/v1/payment-button.js" data-payment_button_id={BUTTON_ID}> </script></form>
      </div>

      <p class="mt-6 text-body-sm text-muted leading-relaxed">
        Your donation helps cover hosting, domain, development, and maintenance costs. Thank you for your support!
      </p>
    </div>
  </main>

  <Footer />
</Layout>
