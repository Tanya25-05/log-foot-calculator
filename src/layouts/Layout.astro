  window.i18n = {
    lang: "en",
    t(key) { return LANG[this.lang]?.[key] ?? LANG.en[key] ?? key; },
    apply(root) {
      (root || document).querySelectorAll("[data-i18n]").forEach(el => { el.textContent = this.t(el.dataset.i18n); });
      (root || document).querySelectorAll("[data-i18n-html]").forEach(el => { el.innerHTML = this.t(el.dataset.i18nHtml); });
    },
    init() { try { this.lang = localStorage.getItem("bfc_lang") || "en"; } catch(e) {} if (!LANG[this.lang]) this.lang = "en"; this.apply(); },
    set(lang) { this.lang = lang; try { localStorage.setItem("bfc_lang", lang); } catch(e) {} this.apply(); document.dispatchEvent(new CustomEvent("i18nchange")); }
  };

  (() => {
    const stored = localStorage.getItem("bfc_theme");
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const isDark = stored === "dark" || (!stored && prefersDark);
    if (isDark) document.documentElement.setAttribute("data-theme", "dark");

    function syncLangSelectors() {
      const lang = window.i18n?.lang || "en";
      document.querySelectorAll("#lang-select, #lang-select-mobile").forEach(sel => { if (sel) sel.value = lang; });
    }

    document.addEventListener("DOMContentLoaded", () => {
      window.i18n.init();
      syncLangSelectors();
      document.querySelectorAll("#lang-select, #lang-select-mobile").forEach(sel => {
        if (!sel) return;
        sel.addEventListener("change", () => {
          window.i18n?.set(sel.value);
          document.querySelectorAll("#lang-select, #lang-select-mobile").forEach(s => { if (s) s.value = sel.value; });
        });
      });
      document.addEventListener("i18nchange", syncLangSelectors);
      const themeBtns = ["theme-toggle", "theme-toggle-mobile"].map(id => document.getElementById(id)).filter(Boolean);
      const sunIcons = ["sun-icon", "sun-icon-mobile"].map(id => document.getElementById(id)).filter(Boolean);
      const moonIcons = ["moon-icon", "moon-icon-mobile"].map(id => document.getElementById(id)).filter(Boolean);
      const updateTheme = () => { const dark = document.documentElement.getAttribute("data-theme") === "dark"; sunIcons.forEach(el => el.classList.toggle("hidden", !dark)); moonIcons.forEach(el => el.classList.toggle("hidden", dark)); };
      updateTheme();
      themeBtns.forEach(btn => { btn.addEventListener("click", () => { const isD = document.documentElement.getAttribute("data-theme") === "dark"; if (isD) { document.documentElement.removeAttribute("data-theme"); localStorage.setItem("bfc_theme", "light"); } else { document.documentElement.setAttribute("data-theme", "dark"); localStorage.setItem("bfc_theme", "dark"); } updateTheme(); }); });
      const menuToggle = document.getElementById("menu-toggle"), mobileMenu = document.getElementById("mobile-menu"), menuIcon = document.getElementById("menu-icon"), closeIcon = document.getElementById("close-icon");
      if (menuToggle && mobileMenu) menuToggle.addEventListener("click", () => { const isO = !mobileMenu.classList.contains("hidden"); mobileMenu.classList.toggle("hidden", isO); menuIcon.classList.toggle("hidden", !isO); closeIcon.classList.toggle("hidden", isO); });

      // Cookie Consent
      const banner = document.getElementById("cookie-banner");
      const acceptBtn = document.getElementById("cookie-accept");
      const declineBtn = document.getElementById("cookie-decline");
      const consentState = (() => { try { return localStorage.getItem("bfc_cookie_consent"); } catch (e) { return null; } })();
      if (!consentState && banner) {
        banner.classList.remove("hidden");
        if (acceptBtn) acceptBtn.addEventListener("click", () => {
          try { localStorage.setItem("bfc_cookie_consent", "accepted"); } catch (e) {}
          banner.classList.add("hidden");
          location.reload();
        });
        if (declineBtn) declineBtn.addEventListener("click", () => {
          try { localStorage.setItem("bfc_cookie_consent", "declined"); } catch (e) {}
          banner.classList.add("hidden");
        });
      }
    });
  })();
</script>
