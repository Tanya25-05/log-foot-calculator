---
import "../styles/global.css";
const { title = "Board Foot Calculator", description = "Free online board foot calculator for lumber." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title} | Modern Board Foot Calculator</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="board foot calculator, lumber calculator, woodworking calculator, board feet, cut list, lumber cost" />
    <link rel="canonical" href="https://boardfootcalc.app/" />

    <meta property="og:title" content={`${title} | Modern Board Foot Calculator`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://boardfootcalc.app/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Modern Board Foot Calculator" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Modern Board Foot Calculator`} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Modern Board Foot Calculator",
      "url": "https://boardfootcalc.app/",
      "description": description,
      "applicationCategory": "Utilities",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })}>
    </script>

    <slot name="head" />
  </head>
  <body class="min-h-screen bg-secondary text-primary font-sans antialiased">
    <slot />
  </body>
</html>

<script>
  (() => {
    const stored = localStorage.getItem("bfc_theme");
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const isDark = stored === "dark" || (!stored && prefersDark);

    if (isDark) {
      document.documentElement.setAttribute("data-theme", "dark");
    }

    document.addEventListener("DOMContentLoaded", () => {
      const btn = document.getElementById("theme-toggle");
      const sun = document.getElementById("sun-icon");
      const moon = document.getElementById("moon-icon");

      if (!btn) return;

      const update = () => {
        const dark = document.documentElement.getAttribute("data-theme") === "dark";
        sun.classList.toggle("hidden", !dark);
        moon.classList.toggle("hidden", dark);
      };

      update();

      btn.addEventListener("click", () => {
        const isDark = document.documentElement.getAttribute("data-theme") === "dark";
        if (isDark) {
          document.documentElement.removeAttribute("data-theme");
          localStorage.setItem("bfc_theme", "light");
        } else {
          document.documentElement.setAttribute("data-theme", "dark");
          localStorage.setItem("bfc_theme", "dark");
        }
        update();
      });
    });
  })();
</script>
